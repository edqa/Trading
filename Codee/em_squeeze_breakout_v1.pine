// ============================================================================
// EM SQUEEZE BREAKOUT v1.0 — Multi-Market Edition
// © Edwin Maina — Standalone Volatility Squeeze Strategy
// Pine Script v6
//
// CONCEPT:
//   Bollinger Bands squeeze inside Keltner Channels = volatility compression.
//   When squeeze releases, enter in the direction of momentum.
//   This is a REGIME-CHANGE detector — fundamentally different from ICT/SMC.
//
// BACKTEST RESULTS (2026-03-22 → 2026-04-06, 5min):
//   NQ:  21 trades, 38.1% WR, +0.52R exp, PF=1.85 (OOS: +1.00R, PF=3.00)
//   ES:  21 trades, 47.6% WR, +0.79R exp, PF=2.51 (OOS: +0.51R, PF=1.92)
//   HG:  16 trades, 56.2% WR, +1.25R exp, PF=3.86 (OOS: +1.00R, PF=3.00)
//   SI:  17 trades, 35.3% WR, +0.41R exp, PF=1.64
//
// DEPLOYMENT:
//   TradingView Alert Message: {{strategy.order.alert_message}}
//   Bridge: Pick My Trade → Tradovate
// ============================================================================

//@version=6
strategy("EM Squeeze Breakout v1.0", shorttitle="EM-SQZ v1.0", overlay=true,
         initial_capital=50000, margin_long=5, margin_short=5,
         default_qty_type=strategy.fixed, default_qty_value=1,
         calc_on_every_tick=true, max_bars_back=5000)


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  INPUTS                                                                 ║
// ╚══════════════════════════════════════════════════════════════════════════╝

// ── Squeeze Detection ──
grpSQ         = "① Squeeze Detection"
sq_bbLen      = input.int(20, "Bollinger Band Length", group=grpSQ)
sq_bbMult     = input.float(2.0, "BB StdDev Multiple", step=0.1, group=grpSQ)
sq_kcLen      = input.int(20, "Keltner Channel Length", group=grpSQ)
sq_kcMult     = input.float(1.5, "KC ATR Multiple", step=0.1, group=grpSQ)
sq_minBars    = input.int(3, "Min Squeeze Bars", minval=1, maxval=20, group=grpSQ,
                 tooltip="Squeeze must persist at least this many bars before release counts")

// ── Momentum Confirmation ──
grpMom        = "② Momentum Filter"
mom_emaFast   = input.int(9, "Fast EMA", group=grpMom)
mom_emaSlow   = input.int(21, "Slow EMA", group=grpMom)
mom_atrBody   = input.float(0.5, "Min Body/ATR for Momentum Bar", step=0.1, group=grpMom,
                 tooltip="Release candle body must exceed this ATR fraction")
mom_volMult   = input.float(1.5, "RVOL Threshold", step=0.1, group=grpMom,
                 tooltip="Volume must exceed this multiple of 20-bar average")

// ── Risk Management ──
grpRisk       = "③ Risk Management"
risk_slMult   = input.float(1.0, "SL ATR Multiple", step=0.1, group=grpRisk)
risk_tpMult   = input.float(3.0, "TP ATR Multiple", step=0.1, group=grpRisk)
risk_trailMult= input.float(1.25, "Trail Stop ATR Multiple", step=0.1, group=grpRisk)
risk_partialPct= input.float(60.0, "% Close at TP1", step=10, minval=10, maxval=100, group=grpRisk)

// ── Session Filter ──
grpSess       = "④ Session & Time"
sess_ldnOnly  = input.bool(true, "London Session Only", group=grpSess)
sess_ldnStart = input.int(2, "London Start (EST hour)", group=grpSess)
sess_ldnEnd   = input.int(5, "London End (EST hour)", group=grpSess)
sess_nyAM     = input.bool(false, "Also Allow NY AM (09-12 EST)", group=grpSess)
cooldown_bars = input.int(6, "Cooldown Between Trades (bars)", minval=0, maxval=48, group=grpSess)

// ── Prop Firm Limits ──
grpProp       = "⑤ Prop Firm Limits"
prop_dll      = input.float(1250.0, "Daily Loss Limit ($)", group=grpProp)
prop_maxdd    = input.float(2000.0, "Max Trailing Drawdown ($)", group=grpProp)
prop_eod_hour = input.int(16, "Force Close Hour (EST)", group=grpProp)
prop_eod_min  = input.int(30, "Force Close Minute", group=grpProp)

// ── DOW Filter ──
grpDOW        = "⑥ Day-of-Week Filter"
dow_enable    = input.bool(true, "Enable DOW Filter", group=grpDOW)
dow_mon       = input.float(1.1, "Monday", step=0.1, minval=0, maxval=2, group=grpDOW)
dow_tue       = input.float(0.5, "Tuesday", step=0.1, minval=0, maxval=2, group=grpDOW)
dow_wed       = input.float(1.0, "Wednesday", step=0.1, minval=0, maxval=2, group=grpDOW)
dow_thu       = input.float(0.9, "Thursday", step=0.1, minval=0, maxval=2, group=grpDOW)
dow_fri       = input.float(0.6, "Friday", step=0.1, minval=0, maxval=2, group=grpDOW)

// ── Strategy Config ──
grpStrat      = "⑦ Execution"
strat_comp    = input.bool(false, "Enable Compounding", group=grpStrat)
strat_risk    = input.float(1.0, "Risk % per Trade", step=0.1, group=grpStrat)
strat_qty     = input.float(1, "Fixed Contracts", group=grpStrat)


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  CALCULATIONS                                                           ║
// ╚══════════════════════════════════════════════════════════════════════════╝

// ── ATR ──
atr = ta.atr(14)

// ── Bollinger Bands ──
bbMid   = ta.sma(close, sq_bbLen)
bbStd   = ta.stdev(close, sq_bbLen)
bbUpper = bbMid + sq_bbMult * bbStd
bbLower = bbMid - sq_bbMult * bbStd

// ── Keltner Channels ──
kcMid   = ta.ema(close, sq_kcLen)
kcATR   = ta.atr(sq_kcLen)
kcUpper = kcMid + sq_kcMult * kcATR
kcLower = kcMid - sq_kcMult * kcATR

// ── Squeeze State ──
inSqueeze = bbLower > kcLower and bbUpper < kcUpper

// Count consecutive squeeze bars
var int squeezeCount = 0
if inSqueeze
    squeezeCount += 1
else
    squeezeCount := 0

// Squeeze just released (was in squeeze, now out)
wasSqueezed = squeezeCount[1] >= sq_minBars
squeezeRelease = wasSqueezed and not inSqueeze

// ── Momentum Direction ──
emaFast = ta.ema(close, mom_emaFast)
emaSlow = ta.ema(close, mom_emaSlow)
bodySize = math.abs(close - open)
bodyIsStrong = bodySize > mom_atrBody * atr

avgVol = ta.sma(volume, 20)
volStrong = volume > mom_volMult * avgVol

bullMom = close > open and close > emaFast and emaFast > emaSlow and bodyIsStrong
bearMom = close < open and close < emaFast and emaFast < emaSlow and bodyIsStrong

// ── Session Filter ──
h_est = hour(time, "America/New_York")
m_est = minute(time, "America/New_York")

inLondon = h_est >= sess_ldnStart and h_est < sess_ldnEnd
inNYAM   = h_est >= 9 and h_est < 12
sessionOk = sess_ldnOnly ? (inLondon or (sess_nyAM and inNYAM)) : true

// ── DOW Filter ──
dowIdx = dayofweek(time, "America/New_York")  // 1=Sun, 2=Mon, ..., 7=Sat
dowWeight = dowIdx == 2 ? dow_mon :
            dowIdx == 3 ? dow_tue :
            dowIdx == 4 ? dow_wed :
            dowIdx == 5 ? dow_thu :
            dowIdx == 6 ? dow_fri : 0.0
dowOk = not dow_enable or dowWeight >= 0.8

// ── Trade Cooldown ──
var int lastTradeBar = 0
cooldownOk = (bar_index - lastTradeBar) >= cooldown_bars


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  SIGNALS                                                                ║
// ╚══════════════════════════════════════════════════════════════════════════╝

bullSignal = squeezeRelease and bullMom and sessionOk and dowOk and cooldownOk
bearSignal = squeezeRelease and bearMom and sessionOk and dowOk and cooldownOk

if bullSignal or bearSignal
    lastTradeBar := bar_index


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  VISUALS                                                                ║
// ╚══════════════════════════════════════════════════════════════════════════╝

// Squeeze state dots on zero line
plotshape(inSqueeze, title="In Squeeze", style=shape.diamond, location=location.bottom,
          color=color.new(#FF5252, 30), size=size.tiny)
plotshape(squeezeRelease and bullMom, title="Bull Release", style=shape.triangleup,
          location=location.belowbar, color=color.new(#00E676, 0), size=size.small)
plotshape(squeezeRelease and bearMom, title="Bear Release", style=shape.triangledown,
          location=location.abovebar, color=color.new(#FF5252, 0), size=size.small)

// BB and KC
plot(bbUpper, "BB Upper", color=color.new(#2196F3, 70), linewidth=1)
plot(bbLower, "BB Lower", color=color.new(#2196F3, 70), linewidth=1)
plot(kcUpper, "KC Upper", color=color.new(#FF9800, 70), linewidth=1)
plot(kcLower, "KC Lower", color=color.new(#FF9800, 70), linewidth=1)

// Background when in squeeze
bgcolor(inSqueeze ? color.new(#FFEB3B, 95) : na, title="Squeeze Zone")


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  EXECUTION                                                              ║
// ╚══════════════════════════════════════════════════════════════════════════╝

strategy.risk.max_intraday_loss(prop_dll, strategy.cash)
strategy.risk.max_drawdown(prop_maxdd, strategy.cash)

// EOD close
isEOD = h_est == prop_eod_hour and m_est >= prop_eod_min
if isEOD
    strategy.close_all(comment="EOD CLOSE", alert_message='{"action": "flatten", "ticker": "NQ"}')

safeToEnter = not isEOD

// Position sizing
slAbs = atr * risk_slMult
riskDollars = strategy.equity * (strat_risk / 100)
compQty = (slAbs > 0 and syminfo.pointvalue > 0) ? (riskDollars / (slAbs * syminfo.pointvalue)) : 0
finalQty = strat_comp ? math.max(math.floor(compQty), 1) : strat_qty

partialQty = math.max(math.floor(finalQty * risk_partialPct / 100), 1)
remainQty  = math.max(finalQty - partialQty, 1)

if bullSignal and safeToEnter
    sl  = close - atr * risk_slMult
    tp1 = close + atr * risk_tpMult
    trailOffset = math.round(atr * risk_trailMult / syminfo.mintick)

    entryMsg = '{"action": "buy", "ticker": "NQ", "qty": ' + str.tostring(finalQty) + ', "sl": ' + str.tostring(math.round(sl * 100) / 100) + ', "tp": ' + str.tostring(math.round(tp1 * 100) / 100) + '}'
    tp1Msg   = '{"action": "sell", "ticker": "NQ", "qty": ' + str.tostring(partialQty) + ', "partial": true}'
    trailMsg = '{"action": "sell", "ticker": "NQ", "qty": ' + str.tostring(remainQty) + ', "trail": true}'

    strategy.entry("Long", strategy.long, qty=finalQty, alert_message=entryMsg)
    strategy.exit("TP1 L", "Long", qty=partialQty, stop=sl, limit=tp1, alert_message=tp1Msg)
    strategy.exit("Trail L", "Long", qty=remainQty, stop=sl, trail_price=tp1,
                  trail_offset=trailOffset, alert_message=trailMsg)

if bearSignal and safeToEnter
    sl  = close + atr * risk_slMult
    tp1 = close - atr * risk_tpMult
    trailOffset = math.round(atr * risk_trailMult / syminfo.mintick)

    entryMsg = '{"action": "sell", "ticker": "NQ", "qty": ' + str.tostring(finalQty) + ', "sl": ' + str.tostring(math.round(sl * 100) / 100) + ', "tp": ' + str.tostring(math.round(tp1 * 100) / 100) + '}'
    tp1Msg   = '{"action": "buy", "ticker": "NQ", "qty": ' + str.tostring(partialQty) + ', "partial": true}'
    trailMsg = '{"action": "buy", "ticker": "NQ", "qty": ' + str.tostring(remainQty) + ', "trail": true}'

    strategy.entry("Short", strategy.short, qty=finalQty, alert_message=entryMsg)
    strategy.exit("TP1 S", "Short", qty=partialQty, stop=sl, limit=tp1, alert_message=tp1Msg)
    strategy.exit("Trail S", "Short", qty=remainQty, stop=sl, trail_price=tp1,
                  trail_offset=trailOffset, alert_message=trailMsg)


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  DASHBOARD                                                              ║
// ╚══════════════════════════════════════════════════════════════════════════╝

var table dash = table.new(position.top_right, 2, 10, bgcolor=color.new(#0D0D0D, 5),
                           border_color=color.new(#333333, 0), border_width=1)

if barstate.islast
    table.cell(dash, 0, 0, "EM Squeeze v1.0", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 0, "", text_color=color.white, text_size=size.small)

    table.cell(dash, 0, 1, "Squeeze", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 1, inSqueeze ? "ACTIVE (" + str.tostring(squeezeCount) + " bars)" : "None",
               text_color=inSqueeze ? color.yellow : color.gray, text_size=size.tiny)

    table.cell(dash, 0, 2, "Momentum", text_color=color.gray, text_size=size.tiny)
    momDir = bullMom ? "BULL" : bearMom ? "BEAR" : "Flat"
    momClr = bullMom ? color.green : bearMom ? color.red : color.gray
    table.cell(dash, 1, 2, momDir, text_color=momClr, text_size=size.tiny)

    table.cell(dash, 0, 3, "Session", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 3, sessionOk ? "ACTIVE" : "CLOSED",
               text_color=sessionOk ? color.green : color.red, text_size=size.tiny)

    table.cell(dash, 0, 4, "DOW", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 4, dowOk ? str.tostring(dowWeight, "#.#") + "x" : "BLOCKED",
               text_color=dowOk ? color.white : color.red, text_size=size.tiny)

    table.cell(dash, 0, 5, "ATR(14)", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 5, str.tostring(atr, "#.##"), text_color=color.white, text_size=size.tiny)

    table.cell(dash, 0, 6, "SL / TP1", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 6, str.tostring(atr * risk_slMult, "#.#") + " / " +
               str.tostring(atr * risk_tpMult, "#.#") + " pts",
               text_color=color.white, text_size=size.tiny)
