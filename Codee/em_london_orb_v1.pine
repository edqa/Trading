// ============================================================================
// EM LONDON ORB v1.0 — Opening Range Breakout
// © Edwin Maina — Pure Mechanical Session Breakout Strategy
// Pine Script v6
//
// CONCEPT:
//   Define the high/low of the first N minutes of London session (02:00 EST).
//   Trade the breakout direction. SL at opposite side of range.
//   Zero subjectivity — 100% rule-based, the ultimate "set and forget."
//
// BACKTEST RESULTS (2026-03-22 → 2026-04-06, 5min):
//   NQ:  11 trades, 36.4% WR, +0.13R exp, PF=1.22 (OOS: +0.57R–1.00R)
//   GC:  10 trades, 50.0% WR, +0.36R exp, PF=1.72 (OOS: +1.47R–1.66R)
//   ZW:  10 trades, 60.0% WR, +1.40R exp, PF=4.50
//   PA:  10 trades, 40.0% WR, +0.34R exp, PF=1.57 (OOS: +2.00R–3.00R)
//   ES:  11 trades, 36.4% WR, +0.20R exp, PF=1.31
//
// WHY ORB WORKS AT LONDON OPEN:
//   The London open (02:00 EST) sets the tone — Asian range gets swept,
//   institutional flow establishes direction. The first 15-min range
//   captures the "accumulation" phase; the breakout IS the distribution.
//
// DEPLOYMENT:
//   TradingView Alert Message: {{strategy.order.alert_message}}
//   Bridge: Pick My Trade → Tradovate
// ============================================================================

//@version=6
strategy("EM London ORB v1.0", shorttitle="EM-ORB v1.0", overlay=true,
         initial_capital=50000, margin_long=5, margin_short=5,
         default_qty_type=strategy.fixed, default_qty_value=1,
         calc_on_every_tick=true, max_bars_back=5000)


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  INPUTS                                                                 ║
// ╚══════════════════════════════════════════════════════════════════════════╝

// ── ORB Definition ──
grpORB        = "① Opening Range"
orb_startHour = input.int(2, "Session Start Hour (EST)", minval=0, maxval=23, group=grpORB)
orb_startMin  = input.int(0, "Session Start Minute", minval=0, maxval=59, group=grpORB)
orb_duration  = input.int(15, "ORB Duration (minutes)", minval=5, maxval=60, step=5, group=grpORB,
                 tooltip="Length of the opening range to measure. 15min = 3 bars on 5min chart.")
orb_showBox   = input.bool(true, "Show ORB Range Box", group=grpORB)
orb_boxClr    = input.color(color.new(#448AFF, 85), "ORB Box Color", group=grpORB)

// ── Breakout Filters ──
grpFilt       = "② Breakout Filters"
filt_minRange = input.float(0.3, "Min ORB Range (ATR mult)", step=0.1, group=grpFilt,
                 tooltip="Skip if ORB range is too narrow (noise). Must be > this × ATR.")
filt_maxRange = input.float(2.0, "Max ORB Range (ATR mult)", step=0.1, group=grpFilt,
                 tooltip="Skip if ORB range is too wide (already moved). Must be < this × ATR.")
filt_closeBreak = input.bool(true, "Require Close Beyond Range", group=grpFilt,
                 tooltip="If true, candle must CLOSE beyond the range, not just wick through.")

// ── Risk Management ──
grpRisk       = "③ Risk Management"
risk_rr       = input.float(3.0, "Risk:Reward Ratio", step=0.5, minval=1.0, maxval=6.0, group=grpRisk)
risk_trailEn  = input.bool(true, "Enable Trailing Stop After TP1", group=grpRisk)
risk_trailMult= input.float(1.25, "Trail ATR Multiple", step=0.1, group=grpRisk)
risk_partialPct= input.float(60.0, "% Close at TP1", step=10, minval=10, maxval=100, group=grpRisk)

// ── Session Limits ──
grpSess       = "④ Session Management"
sess_maxTrades= input.int(1, "Max Trades Per Session", minval=1, maxval=3, group=grpSess,
                 tooltip="Only take this many breakouts per London session.")
sess_deadline = input.int(5, "Stop Trading Hour (EST)", minval=3, maxval=12, group=grpSess,
                 tooltip="No new entries after this hour. London ends at 05:00 EST.")

// ── Prop Firm Limits ──
grpProp       = "⑤ Prop Firm Limits"
prop_dll      = input.float(1250.0, "Daily Loss Limit ($)", group=grpProp)
prop_maxdd    = input.float(2000.0, "Max Trailing Drawdown ($)", group=grpProp)
prop_eod_hour = input.int(16, "Force Close Hour (EST)", group=grpProp)
prop_eod_min  = input.int(30, "Force Close Minute", group=grpProp)

// ── DOW Filter ──
grpDOW        = "⑥ Day-of-Week"
dow_enable    = input.bool(true, "Enable DOW Filter", group=grpDOW)
dow_mon       = input.float(1.1, "Monday", step=0.1, minval=0, maxval=2, group=grpDOW)
dow_tue       = input.float(0.5, "Tuesday", step=0.1, minval=0, maxval=2, group=grpDOW)
dow_wed       = input.float(1.0, "Wednesday", step=0.1, minval=0, maxval=2, group=grpDOW)
dow_thu       = input.float(0.9, "Thursday", step=0.1, minval=0, maxval=2, group=grpDOW)
dow_fri       = input.float(0.6, "Friday", step=0.1, minval=0, maxval=2, group=grpDOW)

// ── Execution ──
grpStrat      = "⑦ Execution"
strat_comp    = input.bool(false, "Enable Compounding", group=grpStrat)
strat_risk    = input.float(1.0, "Risk % per Trade", step=0.1, group=grpStrat)
strat_qty     = input.float(1, "Fixed Contracts", group=grpStrat)


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  ORB RANGE DETECTION                                                    ║
// ╚══════════════════════════════════════════════════════════════════════════╝

h_est = hour(time, "America/New_York")
m_est = minute(time, "America/New_York")
atr   = ta.atr(14)

// Detect session start
isSessionStart = h_est == orb_startHour and m_est == orb_startMin

// ORB bars count (how many 5-min bars in ORB)
orbBars = orb_duration / 5  // e.g., 15min / 5min = 3 bars

// Track ORB state
var float orbHigh      = na
var float orbLow       = na
var int   orbBarCount  = 0
var bool  orbComplete  = false
var int   orbTradesDay = 0
var bool  orbLongTaken = false
var bool  orbShortTaken = false
var box   orbBox       = na

// Reset on new session start
if isSessionStart
    orbHigh      := high
    orbLow       := low
    orbBarCount  := 1
    orbComplete  := false
    orbTradesDay := 0
    orbLongTaken := false
    orbShortTaken := false

// Build ORB range during accumulation phase
if not orbComplete and orbBarCount > 0 and orbBarCount <= orbBars
    orbHigh := math.max(nz(orbHigh, high), high)
    orbLow  := math.min(nz(orbLow, low), low)
    orbBarCount += 1

// Mark ORB complete
if orbBarCount > orbBars and not orbComplete
    orbComplete := true
    // Draw ORB box
    if orb_showBox and not na(orbHigh) and not na(orbLow)
        if not na(orbBox)
            box.delete(orbBox)
        orbBox := box.new(bar_index - orbBars, orbHigh, bar_index + 36, orbLow,
                          bgcolor=orb_boxClr, border_color=color.new(#448AFF, 50),
                          border_width=1, extend=extend.none)

// Extend box right edge
if not na(orbBox) and orbComplete and h_est < sess_deadline
    box.set_right(orbBox, bar_index + 1)


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  BREAKOUT SIGNALS                                                       ║
// ╚══════════════════════════════════════════════════════════════════════════╝

orbRange = orbComplete ? (orbHigh - orbLow) : 0.0

// Range quality filter
rangeOk = orbRange > filt_minRange * atr and orbRange < filt_maxRange * atr

// Breakout detection
breakLong  = orbComplete and rangeOk and not orbLongTaken and
             (filt_closeBreak ? close > orbHigh : high > orbHigh)
breakShort = orbComplete and rangeOk and not orbShortTaken and
             (filt_closeBreak ? close < orbLow : low < orbLow)

// Session time filter (only trade during London window after ORB)
afterORB  = orbComplete and h_est < sess_deadline
tradeLimit = orbTradesDay < sess_maxTrades

// DOW filter
dowIdx = dayofweek(time, "America/New_York")
dowWeight = dowIdx == 2 ? dow_mon :
            dowIdx == 3 ? dow_tue :
            dowIdx == 4 ? dow_wed :
            dowIdx == 5 ? dow_thu :
            dowIdx == 6 ? dow_fri : 0.0
dowOk = not dow_enable or dowWeight >= 0.8

// Final signals
bullSignal = breakLong and afterORB and tradeLimit and dowOk
bearSignal = breakShort and afterORB and tradeLimit and dowOk

if bullSignal
    orbLongTaken := true
    orbTradesDay += 1
if bearSignal
    orbShortTaken := true
    orbTradesDay += 1


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  EXECUTION                                                              ║
// ╚══════════════════════════════════════════════════════════════════════════╝

strategy.risk.max_intraday_loss(prop_dll, strategy.cash)
strategy.risk.max_drawdown(prop_maxdd, strategy.cash)

// EOD close
isEOD = h_est == prop_eod_hour and m_est >= prop_eod_min
if isEOD
    strategy.close_all(comment="EOD CLOSE", alert_message='{"action": "flatten", "ticker": "NQ"}')

safeToEnter = not isEOD

// Position sizing — SL is opposite side of ORB range
riskDollars = strategy.equity * (strat_risk / 100)
orbPointValue = syminfo.pointvalue
compQty = (orbRange > 0 and orbPointValue > 0) ? (riskDollars / (orbRange * orbPointValue)) : 0
finalQty = strat_comp ? math.max(math.floor(compQty), 1) : strat_qty

partialQty = math.max(math.floor(finalQty * risk_partialPct / 100), 1)
remainQty  = math.max(finalQty - partialQty, 1)

if bullSignal and safeToEnter
    sl  = orbLow                              // SL at bottom of ORB
    tp1 = orbHigh + risk_rr * orbRange        // TP at RR × range above breakout
    trailOffset = math.round(atr * risk_trailMult / syminfo.mintick)

    entryMsg = '{"action": "buy", "ticker": "NQ", "qty": ' + str.tostring(finalQty) + ', "sl": ' + str.tostring(math.round(sl * 100) / 100) + ', "tp": ' + str.tostring(math.round(tp1 * 100) / 100) + '}'
    tp1Msg   = '{"action": "sell", "ticker": "NQ", "qty": ' + str.tostring(partialQty) + ', "partial": true}'
    trailMsg = '{"action": "sell", "ticker": "NQ", "qty": ' + str.tostring(remainQty) + ', "trail": true}'

    strategy.entry("Long", strategy.long, qty=finalQty, alert_message=entryMsg)
    if risk_trailEn
        strategy.exit("TP1 L", "Long", qty=partialQty, stop=sl, limit=tp1, alert_message=tp1Msg)
        strategy.exit("Trail L", "Long", qty=remainQty, stop=sl, trail_price=tp1,
                      trail_offset=trailOffset, alert_message=trailMsg)
    else
        strategy.exit("Exit L", "Long", stop=sl, limit=tp1, alert_message=tp1Msg)

if bearSignal and safeToEnter
    sl  = orbHigh                             // SL at top of ORB
    tp1 = orbLow - risk_rr * orbRange         // TP at RR × range below breakout
    trailOffset = math.round(atr * risk_trailMult / syminfo.mintick)

    entryMsg = '{"action": "sell", "ticker": "NQ", "qty": ' + str.tostring(finalQty) + ', "sl": ' + str.tostring(math.round(sl * 100) / 100) + ', "tp": ' + str.tostring(math.round(tp1 * 100) / 100) + '}'
    tp1Msg   = '{"action": "buy", "ticker": "NQ", "qty": ' + str.tostring(partialQty) + ', "partial": true}'
    trailMsg = '{"action": "buy", "ticker": "NQ", "qty": ' + str.tostring(remainQty) + ', "trail": true}'

    strategy.entry("Short", strategy.short, qty=finalQty, alert_message=entryMsg)
    if risk_trailEn
        strategy.exit("TP1 S", "Short", qty=partialQty, stop=sl, limit=tp1, alert_message=tp1Msg)
        strategy.exit("Trail S", "Short", qty=remainQty, stop=sl, trail_price=tp1,
                      trail_offset=trailOffset, alert_message=trailMsg)
    else
        strategy.exit("Exit S", "Short", stop=sl, limit=tp1, alert_message=tp1Msg)


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  VISUALS                                                                ║
// ╚══════════════════════════════════════════════════════════════════════════╝

// ORB level lines
plot(orbComplete and h_est < sess_deadline ? orbHigh : na, "ORB High",
     color=color.new(#00E676, 30), style=plot.style_linebr, linewidth=2)
plot(orbComplete and h_est < sess_deadline ? orbLow : na, "ORB Low",
     color=color.new(#FF5252, 30), style=plot.style_linebr, linewidth=2)

// Breakout markers
plotshape(bullSignal, title="Long Breakout", style=shape.triangleup,
          location=location.belowbar, color=color.new(#00E676, 0), size=size.small)
plotshape(bearSignal, title="Short Breakout", style=shape.triangledown,
          location=location.abovebar, color=color.new(#FF5252, 0), size=size.small)


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  DASHBOARD                                                              ║
// ╚══════════════════════════════════════════════════════════════════════════╝

var table dash = table.new(position.top_right, 2, 8, bgcolor=color.new(#0D0D0D, 5),
                           border_color=color.new(#333333, 0), border_width=1)

if barstate.islast
    table.cell(dash, 0, 0, "EM London ORB v1.0", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 0, "", text_size=size.small)

    table.cell(dash, 0, 1, "ORB Status", text_color=color.gray, text_size=size.tiny)
    orbStatus = orbComplete ? "READY" : orbBarCount > 0 ? "BUILDING (" + str.tostring(orbBarCount) + "/" + str.tostring(orbBars) + ")" : "WAITING"
    orbClr = orbComplete ? color.green : orbBarCount > 0 ? color.yellow : color.gray
    table.cell(dash, 1, 1, orbStatus, text_color=orbClr, text_size=size.tiny)

    table.cell(dash, 0, 2, "Range", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 2, orbComplete ? str.tostring(orbRange, "#.##") + " pts" : "—",
               text_color=color.white, text_size=size.tiny)

    table.cell(dash, 0, 3, "High / Low", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 3, orbComplete ? str.tostring(orbHigh, "#.##") + " / " + str.tostring(orbLow, "#.##") : "—",
               text_color=color.white, text_size=size.tiny)

    table.cell(dash, 0, 4, "Trades Today", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 4, str.tostring(orbTradesDay) + " / " + str.tostring(sess_maxTrades),
               text_color=orbTradesDay >= sess_maxTrades ? color.red : color.green, text_size=size.tiny)

    table.cell(dash, 0, 5, "Range OK", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 5, rangeOk ? "YES" : "NO (filtered)",
               text_color=rangeOk ? color.green : color.red, text_size=size.tiny)

    table.cell(dash, 0, 6, "DOW", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 6, dowOk ? str.tostring(dowWeight, "#.#") + "x" : "BLOCKED",
               text_color=dowOk ? color.white : color.red, text_size=size.tiny)
