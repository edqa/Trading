// ============================================================================
// EM FUTURES STRATEGY v6.0 — NQ EDITION (SECOND-PASS OPTIMIZED)
// © Edwin Maina — Optimized for NQ Futures (Tradeify $50k / $100k Prop)
// ICT + Smart Money + Master Swing Confluence Engine
// Pine Script v6
//
// PASS 1 NQ OPTIMIZATION (2026-04-14, 2-week data):
//   atr_stopMult  1.0  → 0.75   (SL fits $50k 1% risk per contract)
//   atr_tp1Mult   3.0  → 2.0    (achievable on 5min, ~35% hit rate)
//   atr_tp2Mult   3.0  → 4.0    (let trail extend)
//   disp_atrMult  2.0  → 1.5    (3x more displacement signals)
//   lq_sweepWick  0.30 → 0.40   (41%→28% of bars qualify as sweep)
//   of_rvolThresh 1.5  → 2.0    (16%→8.1% of bars qualify)
//   fvg_minATR    0.3  → 0.2    (capture more NQ imbalances)
//   dow_mon       0.7  → 1.1    (Monday is NQ's highest-vol day)
//   dow_tue/wed calibrated, partial_pct 50→60, trail_atrMult 1.5→1.25
//   sig_minConf   4    → 5      (higher bar for NQ noise)
//   prop_minwin   200  → 300    (NQ TP is larger)
//   prop_eod_min  45   → 30     (NQ gaps hard near close)
//   ce_enable     true → false  (formula never fires on NQ 5min)
//
// PASS 2 NQ OPTIMIZATION (2026-04-14, walk-forward 70/30 on 2,951 5min bars):
//   atr_stopMult  0.75 → 0.50   (OOS expectancy +0.95R; tighter SL NQ)
//   atr_tp1Mult   2.0  → 3.0    (OOS: 3.0 dominates across all combos)
//   disp_atrMult  1.5  → 1.25   (more displacement signals without noise)
//   lq_sweepWick  0.40 → 0.45   (stricter wick filter, cleaner reversals)
//   of_rvolThresh 2.0  → 2.5    (only true volume surges qualify)
//   sig_minConf   5    → 6      (raise bar further; fewer, cleaner trades)
//
// SESSION QUALITY (best params, full dataset):
//   London  02-05: 44.4% WR, +2.47R avg  ← PRIMARY session
//   NY AM   09-12: 16.7% WR, +0.30R avg  ← caution, low edge
//   NY PM   13-16:  0.0% WR, -1.00R avg  ← AVOID
//
// DOW ANALYSIS (1hr NQ data):
//   Mon: range 125.6pts (best), Tue: vol 26,786 (highest)
//   Fri: lowest range 80.7pts, lowest volume
// ============================================================================

//@version=6
strategy("EM Tradeify Prop Strategy v6.0 [NQ OPT2]", shorttitle="EM-FSE v6.0 NQ2", overlay=true, initial_capital=50000, margin_long=5, margin_short=5, default_qty_type=strategy.fixed, default_qty_value=1, calc_on_every_tick=true, max_boxes_count=500, max_lines_count=500, max_labels_count=500, max_bars_back=5000)


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  INPUTS                                                                 ║
// ╚══════════════════════════════════════════════════════════════════════════╝

// ── Market Structure ──
grpMS         = "① Market Structure"
ms_enable     = input.bool(true, "Enable Market Structure", group=grpMS)
ms_length     = input.int(5, "Swing Lookback", minval=2, maxval=50, group=grpMS)
ms_showBOS    = input.bool(true, "Show BOS", group=grpMS)
ms_showCHoCH  = input.bool(true, "Show CHoCH", group=grpMS)
ms_bullClr    = input.color(color.new(#00E676, 0), "Bullish", group=grpMS)
ms_bearClr    = input.color(color.new(#FF5252, 0), "Bearish", group=grpMS)

// ── Liquidity Pools ──
grpLQ         = "② Liquidity Pools & Sweeps"
lq_enable     = input.bool(true, "Enable Liquidity Detection", group=grpLQ)
lq_swingLen   = input.int(10, "Liquidity Swing Length", minval=3, maxval=50, group=grpLQ)
lq_sweepWick  = input.float(0.45, "Min Wick Ratio for Sweep", step=0.05, group=grpLQ, tooltip="Wick must be this fraction of total range to qualify as sweep") // NQ OPT2: 0.30→0.45 (stricter sweep filter, cleaner reversals)
lq_poolClr    = input.color(color.new(#FFEB3B, 50), "Liquidity Pool", group=grpLQ)
lq_sweepClr   = input.color(color.new(#E040FB, 0), "Sweep Marker", group=grpLQ)
lq_maxPools   = input.int(20, "Max Pool Lines", minval=5, maxval=50, group=grpLQ)

// ── Fair Value Gaps ──
grpFVG        = "③ Fair Value Gaps (PD Arrays)"
fvg_enable    = input.bool(true, "Enable FVG", group=grpFVG)
fvg_bullClr   = input.color(color.new(#00E676, 82), "Bullish FVG", group=grpFVG)
fvg_bearClr   = input.color(color.new(#FF5252, 82), "Bearish FVG", group=grpFVG)
fvg_oppClr    = input.color(color.new(#FF9800, 60), "Opposing PD Array", group=grpFVG)
fvg_maxBoxes  = input.int(15, "Max FVG Boxes", minval=1, maxval=50, group=grpFVG)
fvg_minATR    = input.float(0.2, "Min FVG Size (ATR mult)", step=0.1, group=grpFVG)  // NQ OPT1: 0.3→0.2 (capture more NQ imbalances ~5.9pts min)
fvg_mitigate  = input.bool(true, "Remove Mitigated", group=grpFVG)

// ── Displacement ──
grpDisp       = "④ Displacement (Phase Change)"
disp_enable   = input.bool(true, "Enable Displacement", group=grpDisp)
disp_atrMult  = input.float(1.25, "ATR Multiple", step=0.1, group=grpDisp)     // NQ OPT2: 2.0→1.25 (more signals, still strong displacement filter)
disp_atrLen   = input.int(14, "ATR Length", group=grpDisp)

// ── Consolidation & Expansion ──
grpCE         = "⑤ Consolidation → Expansion"
ce_enable     = input.bool(false, "Enable Consolidation Detection", group=grpCE) // NQ OPT1: disabled — formula never triggers on NQ 5min; re-enable on daily TF
ce_lookback   = input.int(20, "Consolidation Lookback Bars", minval=5, maxval=100, group=grpCE)
ce_atrRatio   = input.float(0.5, "ATR Compression Ratio", step=0.05, group=grpCE, tooltip="Current range / ATR below this = consolidation")
ce_expMult    = input.float(1.5, "Expansion ATR Multiple", step=0.1, group=grpCE, tooltip="Candle body > this * ATR = expansion")
ce_boxClr     = input.color(color.new(#9E9E9E, 85), "Consolidation Zone", group=grpCE)

// ── Key Levels ──
grpLV         = "⑥ Key Levels (PDH/PDL/MO/Weekly)"
lv_enable     = input.bool(true, "Enable Key Levels", group=grpLV)
lv_pdHL       = input.bool(true, "PDH / PDL", group=grpLV)
lv_pdClose    = input.bool(true, "Prior Day Close", group=grpLV)
lv_midOpen    = input.bool(true, "Midnight Open (00:00 EST)", group=grpLV)
lv_weekHL     = input.bool(true, "Prior Week H/L", group=grpLV)
lv_pdhClr     = input.color(color.new(#FF9800, 0), "PDH/PDL", group=grpLV)
lv_pdcClr     = input.color(color.new(#9C27B0, 0), "PDC", group=grpLV)
lv_midClr     = input.color(color.new(#00BCD4, 0), "Midnight Open", group=grpLV)
lv_wkClr      = input.color(color.new(#FFEB3B, 30), "Weekly H/L", group=grpLV)

// ── Sessions ──
grpSess       = "⑦ Sessions"
sess_enable   = input.bool(true, "Enable Sessions", group=grpSess)
sess_asia     = input.bool(false, "Asia (20:00-00:00 EST)", group=grpSess, tooltip="Default OFF: NQ edge is London-only per walk-forward.")
sess_ldn      = input.bool(true,  "London (02:00-05:00 EST)", group=grpSess)
sess_nyAM     = input.bool(false, "NY AM (09:30-12:00 EST)", group=grpSess, tooltip="Default OFF: live 04/16/2026 showed NY AM trades blew 57% of DD budget.")
sess_nyPM     = input.bool(false, "NY PM (13:30-16:00 EST)", group=grpSess, tooltip="Default OFF: outside evaluated window.")
trade_sessOnly = input.bool(true, "📌 Restrict Trading to Active Sessions", group=grpSess, tooltip="If checked, the strategy will NOT take trades in the 'dead zones' outside of the sessions selected above.")
sess_asiaClr  = input.color(color.new(#E040FB, 93), "Asia", group=grpSess)
sess_ldnClr   = input.color(color.new(#448AFF, 93), "London", group=grpSess)
sess_nyClr    = input.color(color.new(#FF9800, 93), "NY AM", group=grpSess)
sess_nypmClr  = input.color(color.new(#795548, 93), "NY PM", group=grpSess)

// ── VWAP ──
grpVWAP       = "⑧ VWAP & Bands"
vwap_enable   = input.bool(true, "Enable VWAP", group=grpVWAP)
vwap_bands    = input.bool(true, "Show StdDev Bands", group=grpVWAP)
vwap_m1       = input.float(1.0, "Band 1 StdDev", step=0.25, group=grpVWAP)
vwap_m2       = input.float(2.0, "Band 2 StdDev", step=0.25, group=grpVWAP)
vwap_clr      = input.color(color.new(#2196F3, 0), "VWAP Color", group=grpVWAP)

// ── Order Flow & Delta ──
grpOF         = "⑨ Order Flow & Delta"
of_enable     = input.bool(true, "Enable Order Flow Analysis", group=grpOF)
of_trapped    = input.bool(true, "Detect Trapped Traders", group=grpOF)
of_rvolLen    = input.int(20, "RVOL Lookback", group=grpOF)
of_rvolThresh = input.float(2.5, "RVOL Threshold", step=0.1, group=grpOF)      // NQ OPT2: 1.5→2.5 (only true volume surges qualify, ~6% of bars)

// ── Moving Averages ──
grpMA         = "⑩ Moving Averages"
ma_enable     = input.bool(true, "Enable MAs", group=grpMA)
ma_fastLen    = input.int(9, "Fast EMA", group=grpMA)
ma_slowLen    = input.int(21, "Slow EMA", group=grpMA)
ma_trendLen   = input.int(200, "Trend SMA", group=grpMA)
ma_fastClr    = input.color(color.new(#00E676, 0), "Fast", group=grpMA)
ma_slowClr    = input.color(color.new(#FF5252, 0), "Slow", group=grpMA)
ma_trendClr   = input.color(color.new(#FFFFFF, 50), "Trend", group=grpMA)

// ── HTF Confirmation ──
grpHTF        = "⑪ Higher Timeframe"
htf_enable    = input.bool(true, "Enable HTF Filter", group=grpHTF)
htf_tf        = input.timeframe("60", "HTF Timeframe", group=grpHTF)
htf_emaLen    = input.int(21, "HTF EMA Length", group=grpHTF)
htf_swingLen  = input.int(10, "HTF Swing Length", group=grpHTF)

// ── Market Profile ──
grpMP         = "⑫ Market Profile"
mp_enable     = input.bool(true, "Enable Market Profile", group=grpMP)
mp_len        = input.int(50, "Profile Lookback Bars", minval=10, maxval=200, group=grpMP)
mp_rows       = input.int(24, "Price Rows", minval=10, maxval=50, group=grpMP)
mp_pocClr     = input.color(color.new(#FFEB3B, 0), "POC Color", group=grpMP)
mp_vaClr      = input.color(color.new(#2196F3, 85), "Value Area Fill", group=grpMP)

// ── ATR Stops & Targets ──
grpATR        = "⑬ ATR Stops & Targets"
atr_enable    = input.bool(true, "Enable ATR Zones", group=grpATR)
atr_length    = input.int(14, "ATR Period", group=grpATR)
atr_stopMult  = input.float(0.50, "SL ATR Multiple", step=0.1, group=grpATR)   // NQ OPT2: 1.0→0.50 (OOS best; tighter SL improves expectancy)
atr_tp1Mult   = input.float(4.0, "TP1 ATR Multiple", step=0.1, group=grpATR)   // NQ OPT3: 3.0→4.0 (multi-market backtest: OOS exp 0.95R→1.25R)
atr_tp2Mult   = input.float(4.0, "TP2 ATR Multiple", step=0.1, group=grpATR)   // NQ OPT1: 3.0→4.0 (let trail extend on NQ trending moves)
// OPT5: Absolute dollar SL ceiling — defends against trending/high-ATR blowouts (04/16/2026 -$820 incident).
sl_dollarCap_en = input.bool(true, "Cap SL in Dollars", group=grpATR, tooltip="If true, SL distance is min(ATR*mult, $cap/pointvalue). Prevents outlier losses on trending days.")
sl_dollarCap    = input.float(200.0, "Max SL Loss per Contract ($)", minval=50.0, maxval=2000.0, step=50.0, group=grpATR, tooltip="On NQ ($20/pt) → 200 caps SL at 10 pts. On MNQ ($2/pt) → 200 caps SL at 100 pts.")

// ── Signal Engine ──
grpSig        = "⑭ Signal & Probability Engine"
sig_minConf   = input.int(6, "Min Confluence for Signal", minval=1, maxval=15, group=grpSig)  // NQ OPT2: 4→6 (walk-forward confirms 6 minimises noise on NQ 5min)
sig_minProb   = input.int(25, "Minimum Certainty (%)", minval=0, maxval=100, group=grpSig, tooltip="Warning: Values above 30% are highly restrictive.")

// ── Confluence Toggles ──
grpTog        = "⑭.1 Confluence Toggles"
tog_ms        = input.bool(true, "Market Structure", group=grpTog)
tog_choch     = input.bool(true, "CHoCH", group=grpTog)
tog_disp      = input.bool(true, "Displacement", group=grpTog)
tog_sweep     = input.bool(true, "Sweep Reversal", group=grpTog)
tog_vwap      = input.bool(true, "VWAP", group=grpTog)
tog_ema       = input.bool(true, "Focus EMA", group=grpTog)
tog_sma       = input.bool(true, "Trend SMA", group=grpTog)
tog_htf       = input.bool(true, "HTF Bias", group=grpTog)
tog_delta     = input.bool(true, "Delta", group=grpTog)
tog_rvol      = input.bool(true, "RVOL", group=grpTog)
tog_midnight  = input.bool(true, "Midnight Open", group=grpTog)
tog_pd        = input.bool(true, "Premium/Discount", group=grpTog)
tog_trapped   = input.bool(true, "Trapped Traders", group=grpTog)
tog_htfSweep  = input.bool(true, "HTF Sweep", group=grpTog)
tog_poc       = input.bool(true, "POC", group=grpTog)
tog_exp       = input.bool(true, "Expansion", group=grpTog)

// ── ICT Time Models ──
grpICT        = "⑮ ICT Time Models"
ict_enable    = input.bool(true, "Enable ICT Time Models", group=grpICT)
ict_sb_am     = input.bool(true, "Silver Bullet AM (10:00-11:00)", group=grpICT)
ict_sb_pm     = input.bool(true, "Silver Bullet PM (14:00-15:00)", group=grpICT)
ict_macros    = input.bool(true, "ICT Macros (e.g. 09:50-10:10)", group=grpICT)

// ── Tradeify Prop Firm Limits ──
grpProp       = "⑯ Tradeify Prop Firm Hard Limits"
prop_dll_en   = input.bool(true, "🔴 Daily Loss Limit ($)", inline="dll", group=grpProp)
prop_dll      = input.float(1250.0, "", inline="dll", group=grpProp)
prop_maxdd_en = input.bool(true, "🟡 Max Trailing Drawdown ($)", inline="dd", group=grpProp)
prop_maxdd    = input.float(2000.0, "", inline="dd", group=grpProp)
prop_target_en= input.bool(true, "🟢 Daily Profit Target Limit ($)", inline="tgt", group=grpProp)
prop_target   = input.float(1500.0, "", inline="tgt", group=grpProp)
prop_minwin_en= input.bool(true, "🔵 Minimum Expected Profit ($)", inline="min", group=grpProp)
prop_minwin   = input.float(300.0, "", inline="min", group=grpProp)             // NQ OPT1: 200→300 (NQ TP is larger, filter weak R:R)
prop_lq_filter= input.bool(true, "🚫 Filter Bad R:R (< 1.5R) Trades", group=grpProp)
prop_eod_en   = input.bool(true, "🛑 Force Close Time (EST)", inline="eod", group=grpProp)
prop_eod_hour = input.int(16, "", inline="eod", minval=0, maxval=23, group=grpProp)
prop_eod_min  = input.int(30, ":", inline="eod", minval=0, maxval=59, group=grpProp) // NQ OPT1: 45→30 (NQ gaps hard near close, avoid last 30min)

// ── Strategy Configuration ──
grpStrat      = "⑰ Strategy Execution Auto-Trading"
strat_enable  = input.bool(true, "Enable Strategy Mode", group=grpStrat)
strat_comp    = input.bool(true,  "📈 Enable Compounding (Risk %)", group=grpStrat)
strat_risk    = input.float(1.0, "Risk % per Trade", step=0.1, group=grpStrat)
strat_qty     = input.float(1, "Fixed Position Size (Contracts)", group=grpStrat)
strat_cooldown= input.int(6, "Trade Cooldown (bars)", minval=0, maxval=48, group=grpStrat, tooltip="Min bars between entries. 6 bars = 30min on 5min TF. Ablation study: +1.12R exp improvement.")  // NQ OPT3: 0→6 (30-min cooldown filters revenge trades, PF 4.8→8.0)
// PMT alert_message payloads are built dynamically in the execution block
// using str.tostring() so that SL/TP prices are embedded at fire time.
// The static inputs below are kept as fallback / documentation only.
webhook_buy   = input.string('{"action": "buy", "ticker": "NQ", "qty": 1}', "Buy Alert JSON (reference only)", group=grpStrat)
webhook_sell  = input.string('{"action": "sell", "ticker": "NQ", "qty": 1}', "Sell Alert JSON (reference only)", group=grpStrat)

// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  NEW — MASTER SWING INPUTS                                              ║
// ╚══════════════════════════════════════════════════════════════════════════╝

// ── Order Blocks & Breakers ──
grpOB         = "⑱ Order Blocks & Breakers"
ob_enable     = input.bool(true, "Enable Order Block Detection", group=grpOB)
ob_maxBlocks  = input.int(10, "Max Active Order Blocks", minval=3, maxval=30, group=grpOB)
ob_bullClr    = input.color(color.new(#00E676, 75), "Bullish OB", group=grpOB)
ob_bearClr    = input.color(color.new(#FF5252, 75), "Bearish OB", group=grpOB)
ob_breakerClr = input.color(color.new(#FF9800, 70), "Breaker Block", group=grpOB)
ob_showBreakers = input.bool(true, "Show Breaker Blocks", group=grpOB)

// ── Equal Highs/Lows (Engineered Liquidity) ──
grpEQL        = "⑲ Equal Highs/Lows (Engineered Liquidity)"
eql_enable    = input.bool(true, "Enable Equal H/L Detection", group=grpEQL)
eql_tolerance = input.float(0.1, "Tolerance (ATR mult)", step=0.05, group=grpEQL, tooltip="Two swing points within this ATR fraction = equal")
eql_minCount  = input.int(2, "Min Touches for Cluster", minval=2, maxval=5, group=grpEQL)
eql_hiClr     = input.color(color.new(#FFEB3B, 30), "Equal Highs", group=grpEQL)
eql_loClr     = input.color(color.new(#FFEB3B, 30), "Equal Lows", group=grpEQL)

// ── Day-of-Week Bias ──
grpDOW        = "⑳ Day-of-Week Bias"
dow_enable    = input.bool(true, "Enable DOW Weighting", group=grpDOW)
dow_mon       = input.float(1.1, "Monday Weight", step=0.1, minval=0, maxval=2, group=grpDOW)   // NQ OPT1: 0.7→1.1 (Mon = highest range day 125.6pts)
dow_tue       = input.float(0.5, "Tuesday Weight", step=0.1, minval=0, maxval=2, group=grpDOW)  // NQ OPT3: 1.2→0.5 (0% WR on Tue in backtest, nerf heavily)
dow_wed       = input.float(1.0, "Wednesday Weight", step=0.1, minval=0, maxval=2, group=grpDOW) // NQ OPT1: 1.3→1.0
dow_thu       = input.float(0.9, "Thursday Weight", step=0.1, minval=0, maxval=2, group=grpDOW)  // NQ OPT1: 1.0→0.9
dow_fri       = input.float(0.6, "Friday Weight", step=0.1, minval=0, maxval=2, group=grpDOW)    // NQ OPT1: 0.5→0.6

// ── AMD Sub-Session Model ──
grpAMD        = "㉑ AMD Sub-Session Model"
amd_enable    = input.bool(true, "Enable AMD Phase Detection", group=grpAMD)
amd_manipMins = input.int(30, "Manipulation Window (mins from session open)", minval=10, maxval=60, group=grpAMD)
amd_manipPenalty = input.int(3, "Confluence Penalty During Manipulation", minval=1, maxval=5, group=grpAMD)

// ── ADR Exhaustion ──
grpADR        = "㉒ ADR Exhaustion Filter"
adr_enable    = input.bool(true, "Enable ADR Exhaustion", group=grpADR)
adr_len       = input.int(20, "ADR Lookback (Days)", minval=5, maxval=60, group=grpADR)
adr_exhaustPct= input.float(80.0, "Exhaustion Threshold (%)", step=5, minval=50, maxval=100, group=grpADR, tooltip="If price has moved this % of ADR, fade trend-following signals")
adr_boostPct  = input.float(30.0, "Low Exhaustion Boost (%)", step=5, minval=10, maxval=50, group=grpADR, tooltip="Below this = fresh move, boost trend signals")

// ── Effort vs Result (Wyckoff VPA) ──
grpVPA        = "㉓ Effort vs Result (Wyckoff VPA)"
vpa_enable    = input.bool(true, "Enable VPA Detection", group=grpVPA)
vpa_effortMult= input.float(1.5, "High Effort = RVOL above this", step=0.1, group=grpVPA)
vpa_resultATR = input.float(0.3, "Low Result = Body below this ATR mult", step=0.05, group=grpVPA)

// ── Anchored VWAP from Structure ──
grpAVWAP      = "㉔ Anchored VWAP (from CHoCH / Sweep)"
avwap_enable  = input.bool(true, "Enable Anchored VWAP", group=grpAVWAP)
avwap_clr     = input.color(color.new(#E040FB, 30), "Anchored VWAP Color", group=grpAVWAP)

// ── Correlation Divergence Filter ──
grpCorr       = "㉕ Correlation Divergence (ES vs NQ)"
corr_enable   = input.bool(false, "Enable Correlation Filter", group=grpCorr, tooltip="Requires NQ data. Suppresses signals when ES/NQ diverge.")
corr_symbol   = input.symbol("CME_MINI:NQ1!", "Correlation Symbol", group=grpCorr)
corr_len      = input.int(20, "Correlation Lookback", minval=5, maxval=100, group=grpCorr)
corr_minR     = input.float(0.5, "Min Correlation for Signal", step=0.05, group=grpCorr, tooltip="Below this = divergence, suppress signals")

// ── Partial TP & Trailing ──
grpPartial    = "㉖ Partial TP & Trailing Stop"
partial_enable= input.bool(true, "Enable Partial TP + Trail", group=grpPartial)
partial_pct   = input.float(60.0, "% to Close at TP1", step=10, minval=10, maxval=90, group=grpPartial)  // NQ OPT1: 50→60 (bank more at TP1 due to NQ snap-backs)
trail_atrMult = input.float(1.25, "Trail Stop ATR Multiple", step=0.1, group=grpPartial) // NQ OPT1: 1.5→1.25 (tighter trail for NQ reversals)

// ── Bollinger Squeeze (Volatility Compression) ──
grpSqueeze    = "㉗ Bollinger Squeeze"
sq_enable     = input.bool(true, "Enable Squeeze Detection", group=grpSqueeze)
sq_bbLen      = input.int(20, "BB Length", group=grpSqueeze)
sq_bbMult     = input.float(2.0, "BB StdDev", step=0.1, group=grpSqueeze)
sq_kcLen      = input.int(20, "KC Length", group=grpSqueeze)
sq_kcMult     = input.float(1.5, "KC ATR Mult", step=0.1, group=grpSqueeze)

// ── Master Swing Confluence Toggles ──
grpTogMS      = "⑭.2 Master Swing Confluence Toggles"
tog_ob        = input.bool(true, "Order Block", group=grpTogMS)
tog_breaker   = input.bool(true, "Breaker Block", group=grpTogMS)
tog_eql       = input.bool(true, "Equal H/L Cluster", group=grpTogMS)
tog_dow       = input.bool(true, "Day-of-Week", group=grpTogMS)
tog_adr       = input.bool(true, "ADR Exhaustion", group=grpTogMS)
tog_vpa       = input.bool(true, "Effort vs Result", group=grpTogMS)
tog_avwap     = input.bool(true, "Anchored VWAP", group=grpTogMS)
tog_squeeze   = input.bool(true, "Squeeze", group=grpTogMS)
tog_corr      = input.bool(true, "Correlation Filter", group=grpTogMS)


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  UTILITIES                                                              ║
// ╚══════════════════════════════════════════════════════════════════════════╝

f_isNewDay()  => ta.change(time("D")) != 0
f_isNewWeek() => ta.change(time("W")) != 0

f_inSession(startH, endH) =>
    h = hour(time, "America/New_York")
    h >= startH and h < endH

// Minute-precise session check — used where the official open isn't on the hour (NY AM 09:30, NY PM 13:30).
f_inSessionHM(startH, startM, endH, endM) =>
    h = hour(time, "America/New_York")
    m = minute(time, "America/New_York")
    tMin = h * 60 + m
    tMin >= (startH * 60 + startM) and tMin < (endH * 60 + endM)

f_isIctMacro() =>
    h = hour(time, "America/New_York")
    m = minute(time, "America/New_York")
    (h == 9 and m >= 50) or (h == 10 and m < 10) or
      (h == 10 and m >= 50) or (h == 11 and m < 10) or
      (h == 11 and m >= 50) or (h == 12 and m < 10) or
      (h == 13 and m >= 50) or (h == 14 and m < 10) or
      (h == 14 and m >= 50) or (h == 15 and m < 10) or
      (h == 15 and m >= 50)

f_isSilverBullet() =>
    h = hour(time, "America/New_York")
    (ict_sb_am and h == 10) or (ict_sb_pm and h == 14)

f_wickRatioTop(o, h, l, c) =>
    rng = h - l
    rng > 0 ? (h - math.max(o, c)) / rng : 0.0

f_wickRatioBot(o, h, l, c) =>
    rng = h - l
    rng > 0 ? (math.min(o, c) - l) / rng : 0.0

atrGlobal = ta.atr(14)


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  1. MARKET STRUCTURE — BOS / CHoCH                                      ║
// ╚══════════════════════════════════════════════════════════════════════════╝

var float msSwH = na, var float msSwL = na
var int msTrend = 0

pivHi = ta.pivothigh(high, ms_length, ms_length)
pivLo = ta.pivotlow(low, ms_length, ms_length)

var bool bosUp = false, var bool bosDn = false
var bool chochUp = false, var bool chochDn = false
bosUp := false
bosDn := false
chochUp := false
chochDn := false

if ms_enable
    if not na(pivHi)
        msSwH := pivHi
    if not na(pivLo)
        msSwL := pivLo
    if msTrend == 0
        msTrend := close > open ? 1 : -1
    if not na(msSwH) and close > msSwH and msTrend == 1
        bosUp := true
    if not na(msSwL) and close < msSwL and msTrend == -1
        bosDn := true
    if not na(msSwH) and close > msSwH and msTrend == -1
        chochUp := true
        msTrend := 1
    if not na(msSwL) and close < msSwL and msTrend == 1
        chochDn := true
        msTrend := -1

// BOS / CHoCH chart labels removed — see Trade Status panel and dashboard


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  2. LIQUIDITY POOLS, SWEEPS & REVERSALS                                ║
// ╚══════════════════════════════════════════════════════════════════════════╝

lqPivHi = ta.pivothigh(high, lq_swingLen, lq_swingLen)
lqPivLo = ta.pivotlow(low, lq_swingLen, lq_swingLen)

var float[] lqHighs = array.new<float>()
var int[]   lqHighBars = array.new<int>()
var float[] lqLows  = array.new<float>()
var int[]   lqLowBars = array.new<int>()
var line[]  lqLines = array.new<line>()

if lq_enable and not na(lqPivHi)
    array.push(lqHighs, lqPivHi)
    array.push(lqHighBars, bar_index - lq_swingLen)
    if array.size(lqHighs) > lq_maxPools
        array.shift(lqHighs)
        array.shift(lqHighBars)

if lq_enable and not na(lqPivLo)
    array.push(lqLows, lqPivLo)
    array.push(lqLowBars, bar_index - lq_swingLen)
    if array.size(lqLows) > lq_maxPools
        array.shift(lqLows)
        array.shift(lqLowBars)

var bool lqSweepHigh = false
var bool lqSweepLow  = false
var float lqSweptLevel = na
lqSweepHigh := false
lqSweepLow  := false

if lq_enable
    topWickRatio = f_wickRatioTop(open, high, low, close)
    botWickRatio = f_wickRatioBot(open, high, low, close)

    if array.size(lqHighs) > 0
        for i = 0 to array.size(lqHighs) - 1
            lvl = array.get(lqHighs, i)
            if high > lvl and close < lvl and topWickRatio >= lq_sweepWick
                lqSweepHigh := true
                lqSweptLevel := lvl
                break

    if array.size(lqLows) > 0
        for i = 0 to array.size(lqLows) - 1
            lvl = array.get(lqLows, i)
            if low < lvl and close > lvl and botWickRatio >= lq_sweepWick
                lqSweepLow := true
                lqSweptLevel := lvl
                break

sweepBullReversal = lqSweepLow and close > open
sweepBearReversal = lqSweepHigh and close < open

// Sweep reversal chart labels removed


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  3. FAIR VALUE GAPS + OPPOSING PD ARRAYS                                ║
// ╚══════════════════════════════════════════════════════════════════════════╝

var box[] fvgBoxes = array.new<box>()
var int[] fvgTypes = array.new<int>()

swRangeHi = ta.highest(high, 50)
swRangeLo = ta.lowest(low, 50)
equilibrium = (swRangeHi + swRangeLo) / 2.0
inPremium = close > equilibrium
inDiscount = close < equilibrium

if fvg_enable and bar_index > 2
    bullFVG = low > high[2] and (low - high[2]) > atrGlobal * fvg_minATR
    bearFVG = high < low[2] and (low[2] - high) > atrGlobal * fvg_minATR

    if bullFVG
        isOpposing = inPremium
        clr = isOpposing ? fvg_oppClr : fvg_bullClr
        b = box.new(bar_index - 2, low, bar_index + 30, high[2], bgcolor=clr, border_color=color.new(color.green, 60), border_width=1)
        if isOpposing
            box.set_text(b, "OPP PDA")
            box.set_text_color(b, color.new(#FF9800, 0))
            box.set_text_size(b, size.tiny)
        array.push(fvgBoxes, b)
        array.push(fvgTypes, 1)

    if bearFVG
        isOpposing = inDiscount
        clr = isOpposing ? fvg_oppClr : fvg_bearClr
        b = box.new(bar_index - 2, low[2], bar_index + 30, high, bgcolor=clr, border_color=color.new(color.red, 60), border_width=1)
        if isOpposing
            box.set_text(b, "OPP PDA")
            box.set_text_color(b, color.new(#FF9800, 0))
            box.set_text_size(b, size.tiny)
        array.push(fvgBoxes, b)
        array.push(fvgTypes, -1)

    if fvg_mitigate and array.size(fvgBoxes) > 0
        for i = array.size(fvgBoxes) - 1 to 0
            bx = array.get(fvgBoxes, i)
            bxT = box.get_top(bx)
            bxB = box.get_bottom(bx)
            if high >= bxT and low <= bxB
                box.delete(bx)
                array.remove(fvgBoxes, i)
                array.remove(fvgTypes, i)

    while array.size(fvgBoxes) > fvg_maxBoxes
        box.delete(array.shift(fvgBoxes))
        array.shift(fvgTypes)


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  4. DISPLACEMENT (PHASE CHANGE)                                         ║
// ╚══════════════════════════════════════════════════════════════════════════╝

atrDisp  = ta.atr(disp_atrLen)
bodySize = math.abs(close - open)
isDispUp = disp_enable and bodySize > atrDisp * disp_atrMult and close > open
isDispDn = disp_enable and bodySize > atrDisp * disp_atrMult and close < open

// Displacement barcolor removed


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  5. CONSOLIDATION → EXPANSION → LIQUIDITY TARGET                       ║
// ╚══════════════════════════════════════════════════════════════════════════╝

rangeHi   = ta.highest(high, ce_lookback)
rangeLo   = ta.lowest(low, ce_lookback)
rangeSize = rangeHi - rangeLo
atrCE     = ta.atr(ce_lookback)

isConsolidating = ce_enable and (rangeSize < atrCE * ce_atrRatio * ce_lookback / 14.0)

expBody     = math.abs(close - open)
isExpansion = ce_enable and isConsolidating[1] and not isConsolidating and expBody > atrGlobal * ce_expMult
expBull     = isExpansion and close > open
expBear     = isExpansion and close < open

var float expTarget = na
if expBull and array.size(lqHighs) > 0
    nearestAbove = close + atrGlobal * 10
    for i = 0 to array.size(lqHighs) - 1
        lvl = array.get(lqHighs, i)
        if lvl > close and lvl < nearestAbove
            nearestAbove := lvl
    expTarget := nearestAbove < close + atrGlobal * 10 ? nearestAbove : na

if expBear and array.size(lqLows) > 0
    nearestBelow = close - atrGlobal * 10
    for i = 0 to array.size(lqLows) - 1
        lvl = array.get(lqLows, i)
        if lvl < close and lvl > nearestBelow
            nearestBelow := lvl
    expTarget := nearestBelow > close - atrGlobal * 10 ? nearestBelow : na

bgcolor(ce_enable and isConsolidating ? ce_boxClr : na, title="Consolidation BG")
// EXP chart labels removed


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  6. KEY LEVELS — PDH/PDL/PDC/MIDNIGHT OPEN/WEEKLY                       ║
// ╚══════════════════════════════════════════════════════════════════════════╝

[pdh, pdl, pdc] = request.security(syminfo.tickerid, "D", [high[1], low[1], close[1]], lookahead=barmerge.lookahead_on)
[pwh, pwl]      = request.security(syminfo.tickerid, "W", [high[1], low[1]], lookahead=barmerge.lookahead_on)

var float midnightOpen = na
if hour(time, "America/New_York") == 0 and minute(time, "America/New_York") == 0
    midnightOpen := open

plot(lv_enable and lv_pdHL   ? pdh : na, "PDH", lv_pdhClr, 1, plot.style_stepline_diamond)
plot(lv_enable and lv_pdHL   ? pdl : na, "PDL", lv_pdhClr, 1, plot.style_stepline_diamond)
plot(lv_enable and lv_pdClose? pdc : na, "PDC", lv_pdcClr, 1, plot.style_stepline_diamond)
plot(lv_enable and lv_midOpen? midnightOpen : na, "Midnight Open", lv_midClr, 2, plot.style_stepline)
plot(lv_enable and lv_weekHL ? pwh : na, "PWH", lv_wkClr, 1, plot.style_stepline_diamond)
plot(lv_enable and lv_weekHL ? pwl : na, "PWL", lv_wkClr, 1, plot.style_stepline_diamond)
plot(equilibrium, "Equilibrium (50%)", color.new(#9E9E9E, 40), 1, plot.style_cross)


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  7. SESSIONS + SESSION H/L                                              ║
// ╚══════════════════════════════════════════════════════════════════════════╝

inAsia = sess_enable and sess_asia and f_inSession(20, 24)
inLDN  = sess_enable and sess_ldn  and f_inSession(2, 5)
inNY   = sess_enable and sess_nyAM and f_inSessionHM(9, 30, 12, 0)
inNYPM = sess_enable and sess_nyPM and f_inSessionHM(13, 30, 16, 0)

bgcolor(inAsia ? sess_asiaClr : na, title="Asia BG")
bgcolor(inLDN  ? sess_ldnClr  : na, title="LDN BG")
bgcolor(inNY   ? sess_nyClr   : na, title="NY AM BG")
bgcolor(inNYPM ? sess_nypmClr : na, title="NY PM BG")

var float sAsiaHi = na, var float sAsiaLo = na
var float sLdnHi  = na, var float sLdnLo  = na
var float sNyHi   = na, var float sNyLo   = na

if inAsia
    sAsiaHi := na(sAsiaHi) ? high : math.max(sAsiaHi, high)
    sAsiaLo := na(sAsiaLo) ? low  : math.min(sAsiaLo, low)
if not inAsia and inAsia[1]
    sAsiaHi := na
    sAsiaLo := na
if inLDN
    sLdnHi := na(sLdnHi) ? high : math.max(sLdnHi, high)
    sLdnLo := na(sLdnLo) ? low  : math.min(sLdnLo, low)
if not inLDN and inLDN[1]
    sLdnHi := na
    sLdnLo := na
if inNY
    sNyHi := na(sNyHi) ? high : math.max(sNyHi, high)
    sNyLo := na(sNyLo) ? low  : math.min(sNyLo, low)
if not inNY and inNY[1]
    sNyHi := na
    sNyLo := na

var line L_asiaHi = na, var line L_asiaLo = na
var line L_ldnHi  = na, var line L_ldnLo  = na
var line L_nyHi   = na, var line L_nyLo   = na

if inAsia
    if na(sAsiaHi[1]) or not inAsia[1]
        L_asiaHi := line.new(bar_index, sAsiaHi, bar_index, sAsiaHi, color=sess_asiaClr)
        L_asiaLo := line.new(bar_index, sAsiaLo, bar_index, sAsiaLo, color=sess_asiaClr)
    else
        line.set_y1(L_asiaHi, sAsiaHi)
        line.set_y2(L_asiaHi, sAsiaHi)
        line.set_x2(L_asiaHi, bar_index)
        line.set_y1(L_asiaLo, sAsiaLo)
        line.set_y2(L_asiaLo, sAsiaLo)
        line.set_x2(L_asiaLo, bar_index)

if inLDN
    if na(sLdnHi[1]) or not inLDN[1]
        L_ldnHi := line.new(bar_index, sLdnHi, bar_index, sLdnHi, color=sess_ldnClr)
        L_ldnLo := line.new(bar_index, sLdnLo, bar_index, sLdnLo, color=sess_ldnClr)
    else
        line.set_y1(L_ldnHi, sLdnHi)
        line.set_y2(L_ldnHi, sLdnHi)
        line.set_x2(L_ldnHi, bar_index)
        line.set_y1(L_ldnLo, sLdnLo)
        line.set_y2(L_ldnLo, sLdnLo)
        line.set_x2(L_ldnLo, bar_index)

if inNY
    if na(sNyHi[1]) or not inNY[1]
        L_nyHi := line.new(bar_index, sNyHi, bar_index, sNyHi, color=sess_nyClr)
        L_nyLo := line.new(bar_index, sNyLo, bar_index, sNyLo, color=sess_nyClr)
    else
        line.set_y1(L_nyHi, sNyHi)
        line.set_y2(L_nyHi, sNyHi)
        line.set_x2(L_nyHi, bar_index)
        line.set_y1(L_nyLo, sNyLo)
        line.set_y2(L_nyLo, sNyLo)
        line.set_x2(L_nyLo, bar_index)


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  8. VWAP + STANDARD DEVIATION BANDS                                     ║
// ╚══════════════════════════════════════════════════════════════════════════╝

var float vSumPV = 0.0, var float vSumV = 0.0, var float vSumPV2 = 0.0
if f_isNewDay()
    vSumPV := 0.0
    vSumV  := 0.0
    vSumPV2:= 0.0

tp = hlc3
vSumPV  += tp * volume
vSumV   += volume
vSumPV2 += tp * tp * volume

vwapVal = vSumV != 0 ? vSumPV / vSumV : na
vwapStd = vSumV != 0 ? math.sqrt(math.max((vSumPV2 / vSumV) - (vwapVal * vwapVal), 0)) : 0.0

vU1 = vwapVal + vwap_m1 * vwapStd
vL1 = vwapVal - vwap_m1 * vwapStd
vU2 = vwapVal + vwap_m2 * vwapStd
vL2 = vwapVal - vwap_m2 * vwapStd

plot(vwap_enable ? vwapVal : na, "VWAP", vwap_clr, 2)
pVU1 = plot(vwap_enable and vwap_bands ? vU1 : na, "VWAP +1σ", color.new(vwap_clr, 70))
pVL1 = plot(vwap_enable and vwap_bands ? vL1 : na, "VWAP -1σ", color.new(vwap_clr, 70))
pVU2 = plot(vwap_enable and vwap_bands ? vU2 : na, "VWAP +2σ", color.new(vwap_clr, 85))
pVL2 = plot(vwap_enable and vwap_bands ? vL2 : na, "VWAP -2σ", color.new(vwap_clr, 85))
fill(pVU1, pVL1, color.new(vwap_clr, 93), "VWAP Band 1")
fill(pVU2, pVL2, color.new(vwap_clr, 96), "VWAP Band 2")


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  9. ORDER FLOW — DELTA, RVOL, TRAPPED TRADERS                          ║
// ╚══════════════════════════════════════════════════════════════════════════╝

deltaApx = 0.0
if of_enable and volume > 0
    rng = high - low
    if rng > 0
        deltaApx := volume * ((close - low) / rng) - volume * ((high - close) / rng)
    else
        deltaApx := close >= open ? volume : -volume

var float cumDelta = 0.0
if f_isNewDay()
    cumDelta := 0.0
cumDelta += deltaApx

avgVol    = ta.sma(volume, of_rvolLen)
rvolRatio = avgVol > 0 ? volume / avgVol : 0.0
rvolHigh  = of_enable and rvolRatio >= of_rvolThresh

trappedLongs = of_trapped and close[1] > open[1] and (close[1] - open[1]) > atrGlobal * 1.0 and close < open[1] and volume > avgVol
trappedShorts = of_trapped and close[1] < open[1] and (open[1] - close[1]) > atrGlobal * 1.0 and close > open[1] and volume > avgVol

failedAuctionHi = high > high[1] and close < low[1] and rvolHigh
failedAuctionLo = low < low[1] and close > high[1] and rvolHigh

// TRAP chart labels removed


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  10. MOVING AVERAGES                                                    ║
// ╚══════════════════════════════════════════════════════════════════════════╝

emaFast  = ta.ema(close, ma_fastLen)
emaSlow  = ta.ema(close, ma_slowLen)
smaTrend = ta.sma(close, ma_trendLen)

plot(ma_enable ? emaFast  : na, "Fast EMA",  ma_fastClr,  1)
plot(ma_enable ? emaSlow  : na, "Slow EMA",  ma_slowClr,  1)
plot(ma_enable ? smaTrend : na, "Trend SMA", ma_trendClr, 2)


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  11. HTF CONFIRMATION + HTF LIQUIDITY SWEEP CHECK                       ║
// ╚══════════════════════════════════════════════════════════════════════════╝

htfEma   = request.security(syminfo.tickerid, htf_tf, ta.ema(close, htf_emaLen), lookahead=barmerge.lookahead_off)
htfClose = request.security(syminfo.tickerid, htf_tf, close, lookahead=barmerge.lookahead_off)
htfHigh  = request.security(syminfo.tickerid, htf_tf, high, lookahead=barmerge.lookahead_off)
htfLow   = request.security(syminfo.tickerid, htf_tf, low, lookahead=barmerge.lookahead_off)

htfBull = htf_enable ? htfClose > htfEma : true
htfBear = htf_enable ? htfClose < htfEma : true

htfSwH = request.security(syminfo.tickerid, htf_tf, ta.pivothigh(high, htf_swingLen, htf_swingLen), lookahead=barmerge.lookahead_off)
htfSwL = request.security(syminfo.tickerid, htf_tf, ta.pivotlow(low, htf_swingLen, htf_swingLen), lookahead=barmerge.lookahead_off)

var float lastHTFSwH = na
var float lastHTFSwL = na
if not na(htfSwH)
    lastHTFSwH := htfSwH
if not na(htfSwL)
    lastHTFSwL := htfSwL

htfBuySweep  = not na(lastHTFSwH) and htfHigh > lastHTFSwH and htfClose < lastHTFSwH
htfSellSweep = not na(lastHTFSwL) and htfLow < lastHTFSwL and htfClose > lastHTFSwL

var bool htfBuySweepFlag  = false
var bool htfSellSweepFlag = false

if htfBuySweep and not htfBuySweep[1]
    htfBuySweepFlag := true
else
    htfBuySweepFlag := false

if htfSellSweep and not htfSellSweep[1]
    htfSellSweepFlag := true
else
    htfSellSweepFlag := false


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  12. MARKET PROFILE — POC & VALUE AREA                                  ║
// ╚══════════════════════════════════════════════════════════════════════════╝

var float pocLevel = na
var float vaHigh   = na
var float vaLow    = na

profileHi = ta.highest(high, mp_len)
profileLo = ta.lowest(low, mp_len)
profileRowSize = (profileHi - profileLo) / mp_rows

if mp_enable and barstate.islast
    if profileRowSize > 0
        maxVol   = 0.0
        maxRow   = 0
        totalVol = 0.0
        volArr = array.new<float>(mp_rows, 0.0)

        for b = 0 to mp_len - 1
            for r = 0 to mp_rows - 1
                rowLo = profileLo + r * profileRowSize
                rowHi = rowLo + profileRowSize
                barLo = low[b]
                barHi = high[b]
                overlap = math.max(0.0, math.min(barHi, rowHi) - math.max(barLo, rowLo))
                barRng  = barHi - barLo
                if barRng > 0 and overlap > 0
                    proportion = overlap / barRng
                    allocated  = volume[b] * proportion
                    currentVol = array.get(volArr, r) + allocated
                    array.set(volArr, r, currentVol)

        for r = 0 to mp_rows - 1
            rv = array.get(volArr, r)
            totalVol += rv
            if rv > maxVol
                maxVol := rv
                maxRow := r

        pocLevel := profileLo + (maxRow + 0.5) * profileRowSize

        vaTarget = totalVol * 0.70
        vaVol    = maxVol
        hiIdx    = maxRow
        loIdx    = maxRow

        for _step = 0 to mp_rows - 1
            if vaVol >= vaTarget
                break
            addHi = hiIdx < mp_rows - 1 ? array.get(volArr, hiIdx + 1) : 0.0
            addLo = loIdx > 0           ? array.get(volArr, loIdx - 1) : 0.0
            if addHi >= addLo and hiIdx < mp_rows - 1
                hiIdx += 1
                vaVol += addHi
            else if loIdx > 0
                loIdx -= 1
                vaVol += addLo
            else
                break

        vaHigh := profileLo + (hiIdx + 1) * profileRowSize
        vaLow  := profileLo + loIdx * profileRowSize

plot(mp_enable ? pocLevel : na, "POC", mp_pocClr, 2, plot.style_cross)
plot(mp_enable ? vaHigh   : na, "VA High", color.new(#2196F3, 50), 1, plot.style_cross)
plot(mp_enable ? vaLow    : na, "VA Low",  color.new(#2196F3, 50), 1, plot.style_cross)


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  13. MID-RANGE EXPOSURE DETECTION                                       ║
// ╚══════════════════════════════════════════════════════════════════════════╝

rangeMid   = equilibrium
midZoneHi  = equilibrium + (swRangeHi - swRangeLo) * 0.10
midZoneLo  = equilibrium - (swRangeHi - swRangeLo) * 0.10
inMidRange = close >= midZoneLo and close <= midZoneHi

bgcolor(inMidRange and ce_enable ? color.new(#9E9E9E, 95) : na, title="Mid-Range Zone")


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  NEW 18. ORDER BLOCKS & BREAKER BLOCKS                                  ║
// ╚══════════════════════════════════════════════════════════════════════════╝

// Order Block = last opposing candle before displacement
// Bullish OB: last bearish candle before a bullish displacement
// Bearish OB: last bullish candle before a bearish displacement

var box[] obBoxes     = array.new<box>()
var int[] obTypes     = array.new<int>()    // 1 = bullish OB, -1 = bearish OB
var float[] obMids    = array.new<float>()  // 50% level for sniper entry
var bool[] obBroken   = array.new<bool>()   // tracks if OB failed (becomes breaker)

var bool nearBullOB = false
var bool nearBearOB = false
var bool nearBullBreaker = false
var bool nearBearBreaker = false
nearBullOB := false
nearBearOB := false
nearBullBreaker := false
nearBearBreaker := false

if ob_enable
    // Detect new bullish OB: previous bar was bearish, current bar is bullish displacement
    if isDispUp and close[1] < open[1]
        obTop = open[1]
        obBot = close[1]
        obMid = (obTop + obBot) / 2.0
        b = box.new(bar_index - 1, obTop, bar_index + 30, obBot, bgcolor=ob_bullClr, border_color=color.new(#00E676, 40), border_width=1, text="OB", text_color=color.new(#00E676, 40), text_size=size.tiny)
        array.push(obBoxes, b)
        array.push(obTypes, 1)
        array.push(obMids, obMid)
        array.push(obBroken, false)

    // Detect new bearish OB: previous bar was bullish, current bar is bearish displacement
    if isDispDn and close[1] > open[1]
        obTop = close[1]
        obBot = open[1]
        obMid = (obTop + obBot) / 2.0
        b = box.new(bar_index - 1, obTop, bar_index + 30, obBot, bgcolor=ob_bearClr, border_color=color.new(#FF5252, 40), border_width=1, text="OB", text_color=color.new(#FF5252, 40), text_size=size.tiny)
        array.push(obBoxes, b)
        array.push(obTypes, -1)
        array.push(obMids, obMid)
        array.push(obBroken, false)

    // Check OB interaction: mitigation, failure (breaker), or proximity
    if array.size(obBoxes) > 0
        for i = array.size(obBoxes) - 1 to 0
            bx    = array.get(obBoxes, i)
            bxT   = box.get_top(bx)
            bxB   = box.get_bottom(bx)
            bxMid = array.get(obMids, i)
            bxTyp = array.get(obTypes, i)
            isBrk = array.get(obBroken, i)

            if not isBrk
                // Price touching the OB zone = near OB
                if bxTyp == 1 and low <= bxT and low >= bxB
                    nearBullOB := true
                if bxTyp == -1 and high >= bxB and high <= bxT
                    nearBearOB := true

                // OB failure: price closes through the OB entirely
                // Bullish OB fails if price closes below its bottom
                if bxTyp == 1 and close < bxB
                    array.set(obBroken, i, true)
                    if ob_showBreakers
                        box.set_bgcolor(bx, ob_breakerClr)
                        box.set_text(bx, "BRK")
                        box.set_text_color(bx, color.new(#FF9800, 0))
                // Bearish OB fails if price closes above its top
                if bxTyp == -1 and close > bxT
                    array.set(obBroken, i, true)
                    if ob_showBreakers
                        box.set_bgcolor(bx, ob_breakerClr)
                        box.set_text(bx, "BRK")
                        box.set_text_color(bx, color.new(#FF9800, 0))

            else
                // Breaker block interaction: price returns to the broken OB zone
                // A broken bullish OB becomes a bearish breaker (resistance)
                if bxTyp == 1 and high >= bxB and high <= bxT
                    nearBearBreaker := true
                // A broken bearish OB becomes a bullish breaker (support)
                if bxTyp == -1 and low <= bxT and low >= bxB
                    nearBullBreaker := true

                // Remove breaker once fully mitigated (price passes through again)
                if bxTyp == 1 and close > bxT
                    box.delete(bx)
                    array.remove(obBoxes, i)
                    array.remove(obTypes, i)
                    array.remove(obMids, i)
                    array.remove(obBroken, i)
                    continue
                if bxTyp == -1 and close < bxB
                    box.delete(bx)
                    array.remove(obBoxes, i)
                    array.remove(obTypes, i)
                    array.remove(obMids, i)
                    array.remove(obBroken, i)
                    continue

    // Cap OB count
    while array.size(obBoxes) > ob_maxBlocks
        box.delete(array.shift(obBoxes))
        array.shift(obTypes)
        array.shift(obMids)
        array.shift(obBroken)


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  NEW 19. EQUAL HIGHS / EQUAL LOWS (ENGINEERED LIQUIDITY)                ║
// ╚══════════════════════════════════════════════════════════════════════════╝

// Detect clusters of swing highs or lows at nearly identical prices
var bool eqlHighsDetected = false
var bool eqlLowsDetected  = false
var float eqlHighLevel    = na
var float eqlLowLevel     = na
eqlHighsDetected := false
eqlLowsDetected  := false

if eql_enable and array.size(lqHighs) >= eql_minCount
    // Check each swing high against others for clustering
    for i = 0 to array.size(lqHighs) - 1
        lvl = array.get(lqHighs, i)
        touches = 0
        for j = 0 to array.size(lqHighs) - 1
            if i != j
                other = array.get(lqHighs, j)
                if math.abs(lvl - other) < atrGlobal * eql_tolerance
                    touches += 1
        if touches >= eql_minCount - 1
            eqlHighsDetected := true
            eqlHighLevel := lvl
            break

if eql_enable and array.size(lqLows) >= eql_minCount
    for i = 0 to array.size(lqLows) - 1
        lvl = array.get(lqLows, i)
        touches = 0
        for j = 0 to array.size(lqLows) - 1
            if i != j
                other = array.get(lqLows, j)
                if math.abs(lvl - other) < atrGlobal * eql_tolerance
                    touches += 1
        if touches >= eql_minCount - 1
            eqlLowsDetected := true
            eqlLowLevel := lvl
            break

// Price approaching engineered liquidity
eqlNearHigh = eqlHighsDetected and not na(eqlHighLevel) and math.abs(high - eqlHighLevel) < atrGlobal * 0.5
eqlNearLow  = eqlLowsDetected and not na(eqlLowLevel) and math.abs(low - eqlLowLevel) < atrGlobal * 0.5

plot(eql_enable and eqlHighsDetected ? eqlHighLevel : na, "EQL Highs", eql_hiClr, 2, plot.style_circles)
plot(eql_enable and eqlLowsDetected  ? eqlLowLevel  : na, "EQL Lows",  eql_loClr, 2, plot.style_circles)


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  NEW 20. DAY-OF-WEEK BIAS                                               ║
// ╚══════════════════════════════════════════════════════════════════════════╝

dow = dayofweek(time, "America/New_York")
dowWeight = dow_enable ? (dow == dayofweek.monday ? dow_mon : dow == dayofweek.tuesday ? dow_tue : dow == dayofweek.wednesday ? dow_wed : dow == dayofweek.thursday ? dow_thu : dow == dayofweek.friday ? dow_fri : 1.0) : 1.0


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  NEW 21. AMD SUB-SESSION MODEL                                          ║
// ╚══════════════════════════════════════════════════════════════════════════╝

// Detect manipulation phase = first N minutes of each major session
h_est = hour(time, "America/New_York")
m_est = minute(time, "America/New_York")

// Session open times (EST): LDN=02:00, NY=09:30, NYPM=13:30
amd_inManip = false
if amd_enable
    // London manipulation: 02:00 to 02:00+manipMins
    if inLDN and h_est == 2 and m_est < amd_manipMins
        amd_inManip := true
    // NY AM manipulation: 09:30 to 09:30+manipMins
    if inNY and ((h_est == 9 and m_est >= 30 and m_est < 30 + amd_manipMins) or (amd_manipMins > 30 and h_est == 10 and m_est < amd_manipMins - 30))
        amd_inManip := true
    // NY PM manipulation: 13:30 to 13:30+manipMins
    if inNYPM and ((h_est == 13 and m_est >= 30 and m_est < 30 + amd_manipMins) or (amd_manipMins > 30 and h_est == 14 and m_est < amd_manipMins - 30))
        amd_inManip := true

bgcolor(amd_inManip ? color.new(#FF5722, 95) : na, title="AMD Manipulation Phase")


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  NEW 22. ADR EXHAUSTION FILTER                                          ║
// ╚══════════════════════════════════════════════════════════════════════════╝

// Average Daily Range from higher timeframe
adr_hi = request.security(syminfo.tickerid, "D", ta.sma(high - low, adr_len), lookahead=barmerge.lookahead_on)

// Today's range so far
var float todayHi = na
var float todayLo = na
if f_isNewDay()
    todayHi := high
    todayLo := low
else
    todayHi := math.max(nz(todayHi, high), high)
    todayLo := math.min(nz(todayLo, low), low)

todayRange = todayHi - todayLo
adr_pctUsed = not na(adr_hi) and adr_hi > 0 ? (todayRange / adr_hi) * 100 : 0.0
adr_exhausted = adr_enable and adr_pctUsed >= adr_exhaustPct
adr_fresh     = adr_enable and adr_pctUsed <= adr_boostPct


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  NEW 23. EFFORT VS RESULT (WYCKOFF VPA)                                 ║
// ╚══════════════════════════════════════════════════════════════════════════╝

// High effort (volume) + low result (small body) = absorption
vpa_highEffort = vpa_enable and rvolRatio >= vpa_effortMult
vpa_lowResult  = vpa_enable and bodySize < atrGlobal * vpa_resultATR

// Absorption detected
vpa_absorption = vpa_highEffort and vpa_lowResult

// Effort vs Result divergence: high volume bullish candle fails to make new BOS
vpa_bullAbsorb = vpa_absorption and deltaApx > 0   // buyers absorbed (bearish signal)
vpa_bearAbsorb = vpa_absorption and deltaApx < 0   // sellers absorbed (bullish signal)

// VPA absorption chart labels removed


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  NEW 24. ANCHORED VWAP FROM STRUCTURE SHIFT                             ║
// ╚══════════════════════════════════════════════════════════════════════════╝

// Reset anchored VWAP from the most recent CHoCH or sweep reversal
var float avSumPV = 0.0, var float avSumV = 0.0
var bool avActive = false
var float avwapLevel = na

// Anchor on CHoCH or sweep reversal events
avReset = chochUp or chochDn or sweepBullReversal or sweepBearReversal

if avwap_enable
    if avReset
        avSumPV := hlc3 * volume
        avSumV  := volume
        avActive := true
    else if avActive
        avSumPV += hlc3 * volume
        avSumV  += volume

    avwapLevel := avActive and avSumV > 0 ? avSumPV / avSumV : na

plot(avwap_enable and avActive ? avwapLevel : na, "Anchored VWAP", avwap_clr, 2, plot.style_line)


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  NEW 25. CORRELATION DIVERGENCE FILTER (ES vs NQ)                       ║
// ╚══════════════════════════════════════════════════════════════════════════╝

corrClose = request.security(corr_symbol, timeframe.period, close, lookahead=barmerge.lookahead_off)
corrVal   = corr_enable ? ta.correlation(close, corrClose, corr_len) : 1.0
corrDivergence = corr_enable and not na(corrVal) and corrVal < corr_minR


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  NEW 27. BOLLINGER SQUEEZE (VOLATILITY COMPRESSION)                     ║
// ╚══════════════════════════════════════════════════════════════════════════╝

// Squeeze = BB inside KC (Bollinger Bands narrower than Keltner Channels)
bbBasis = ta.sma(close, sq_bbLen)
bbDev   = ta.stdev(close, sq_bbLen) * sq_bbMult
bbUpper = bbBasis + bbDev
bbLower = bbBasis - bbDev

kcBasis = ta.sma(close, sq_kcLen)
kcRange = ta.atr(sq_kcLen) * sq_kcMult
kcUpper = kcBasis + kcRange
kcLower = kcBasis - kcRange

sqOn  = sq_enable and bbLower > kcLower and bbUpper < kcUpper  // squeeze is ON
sqOff = sq_enable and not sqOn                                  // squeeze released

// Squeeze just fired (released after being on)
sqFired = sqOff and sqOn[1]

// Momentum direction at squeeze release
sqMom = ta.linreg(close - bbBasis, sq_bbLen, 0)
sqBullFire = sqFired and sqMom > 0
sqBearFire = sqFired and sqMom < 0

bgcolor(sqOn ? color.new(#FF5722, 95) : na, title="Squeeze Active")

// Squeeze fire chart labels removed


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  14. DIRECTIONAL BIAS ENGINE (EXPANDED)                                 ║
// ╚══════════════════════════════════════════════════════════════════════════╝

var int biasBull = 0
var int biasBear = 0
biasBull := 0
biasBear := 0

closePos = high != low ? (close - low) / (high - low) : 0.5

if closePos > 0.70
    biasBull += 2
else if closePos < 0.30
    biasBear += 2
else if closePos > 0.55
    biasBull += 1
else if closePos < 0.45
    biasBear += 1

if deltaApx > 0 and rvolHigh
    biasBull += 2
else if deltaApx > 0
    biasBull += 1
if deltaApx < 0 and rvolHigh
    biasBear += 2
else if deltaApx < 0
    biasBear += 1

if cumDelta > 0 and cumDelta > cumDelta[5]
    biasBull += 1
if cumDelta < 0 and cumDelta < cumDelta[5]
    biasBear += 1

if not na(midnightOpen)
    if close > midnightOpen
        biasBull += 2
    else
        biasBear += 2

if not na(vwapVal)
    if close > vwapVal
        biasBull += 1
    else
        biasBear += 1

if msTrend == 1
    biasBull += 2
else if msTrend == -1
    biasBear += 2

if htfBull
    biasBull += 2
if htfBear
    biasBear += 2

if ma_enable and emaFast > emaSlow and close > smaTrend
    biasBull += 2
else if ma_enable and emaFast < emaSlow and close < smaTrend
    biasBear += 2

if inDiscount
    biasBull += 1
if inPremium
    biasBear += 1

if sweepBullReversal
    biasBull += 3
if sweepBearReversal
    biasBear += 3

if htfSellSweepFlag
    biasBull += 2
if htfBuySweepFlag
    biasBear += 2

if trappedLongs
    biasBear += 2
if trappedShorts
    biasBull += 2

if expBull
    biasBull += 2
if expBear
    biasBear += 2

// NEW: Master Swing bias additions
if nearBullOB
    biasBull += 2
if nearBearOB
    biasBear += 2
if nearBullBreaker
    biasBull += 2
if nearBearBreaker
    biasBear += 2
if vpa_bullAbsorb
    biasBear += 2  // buying absorbed = bearish
if vpa_bearAbsorb
    biasBull += 2  // selling absorbed = bullish
if sqBullFire
    biasBull += 3
if sqBearFire
    biasBear += 3
if eqlNearHigh
    biasBear += 1  // approaching engineered sell-side liquidity
if eqlNearLow
    biasBull += 1  // approaching engineered buy-side liquidity

biasTotal = biasBull + biasBear
biasNet   = biasBull - biasBear

biasDir = biasNet > 4 ? "STRONG BULL" : biasNet > 1 ? "LEAN BULL" : biasNet < -4 ? "STRONG BEAR" : biasNet < -1 ? "LEAN BEAR" : "NEUTRAL"
biasClr = biasNet > 4 ? ms_bullClr : biasNet > 1 ? color.new(#00E676, 40) : biasNet < -4 ? ms_bearClr : biasNet < -1 ? color.new(#FF5252, 40) : color.gray


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  15. CONFLUENCE SCORING & PROBABILITY ENGINE (EXPANDED)                 ║
// ╚══════════════════════════════════════════════════════════════════════════╝

atrVal = ta.atr(atr_length)

// ── Bullish Confluence ──
bullConf = 0
if tog_ms and ms_enable and msTrend == 1
    bullConf += 1
if tog_choch and chochUp
    bullConf += 2
if tog_disp and isDispUp
    bullConf += 2
if tog_sweep and sweepBullReversal
    bullConf += 3
if tog_vwap and vwap_enable and close > vwapVal
    bullConf += 1
if tog_ema and ma_enable and emaFast > emaSlow
    bullConf += 1
if tog_sma and ma_enable and close > smaTrend
    bullConf += 1
if tog_htf and htfBull
    bullConf += 1
if tog_delta and deltaApx > 0
    bullConf += 1
if tog_rvol and rvolHigh
    bullConf += 1
if tog_midnight and not na(midnightOpen) and close > midnightOpen
    bullConf += 1
if tog_pd and inDiscount
    bullConf += 1
if tog_trapped and trappedShorts
    bullConf += 2
if tog_htfSweep and htfSellSweepFlag
    bullConf += 2
if tog_poc and not na(pocLevel) and math.abs(close - pocLevel) < atrVal * 0.5
    bullConf += 1
if tog_exp and expBull
    bullConf += 2

// NEW: Master Swing confluences (bullish)
if tog_ob and nearBullOB
    bullConf += 2
if tog_breaker and nearBullBreaker
    bullConf += 2
if tog_eql and eqlNearLow
    bullConf += 2  // equal lows = engineered liquidity below, expect sweep + reversal up
if tog_vpa and vpa_bearAbsorb
    bullConf += 2  // sellers absorbed = bullish
if tog_avwap and avwap_enable and not na(avwapLevel) and close > avwapLevel
    bullConf += 1
if tog_squeeze and sqBullFire
    bullConf += 3
if tog_adr and adr_fresh
    bullConf += 1  // fresh ADR = room to run
if tog_adr and adr_exhausted
    bullConf -= 2  // exhausted = fade trend

// ── Bearish Confluence ──
bearConf = 0
if tog_ms and ms_enable and msTrend == -1
    bearConf += 1
if tog_choch and chochDn
    bearConf += 2
if tog_disp and isDispDn
    bearConf += 2
if tog_sweep and sweepBearReversal
    bearConf += 3
if tog_vwap and vwap_enable and close < vwapVal
    bearConf += 1
if tog_ema and ma_enable and emaFast < emaSlow
    bearConf += 1
if tog_sma and ma_enable and close < smaTrend
    bearConf += 1
if tog_htf and htfBear
    bearConf += 1
if tog_delta and deltaApx < 0
    bearConf += 1
if tog_rvol and rvolHigh
    bearConf += 1
if tog_midnight and not na(midnightOpen) and close < midnightOpen
    bearConf += 1
if tog_pd and inPremium
    bearConf += 1
if tog_trapped and trappedLongs
    bearConf += 2
if tog_htfSweep and htfBuySweepFlag
    bearConf += 2
if tog_poc and not na(pocLevel) and math.abs(close - pocLevel) < atrVal * 0.5
    bearConf += 1
if tog_exp and expBear
    bearConf += 2

// NEW: Master Swing confluences (bearish)
if tog_ob and nearBearOB
    bearConf += 2
if tog_breaker and nearBearBreaker
    bearConf += 2
if tog_eql and eqlNearHigh
    bearConf += 2  // equal highs = engineered liquidity above, expect sweep + reversal down
if tog_vpa and vpa_bullAbsorb
    bearConf += 2  // buyers absorbed = bearish
if tog_avwap and avwap_enable and not na(avwapLevel) and close < avwapLevel
    bearConf += 1
if tog_squeeze and sqBearFire
    bearConf += 3
if tog_adr and adr_fresh
    bearConf += 1
if tog_adr and adr_exhausted
    bearConf -= 2

// ICT Time Macros & Silver Bullet Boost
if ict_enable and (f_isIctMacro() or f_isSilverBullet())
    bullConf += 2
    bearConf += 2

// AMD manipulation penalty
if amd_enable and amd_inManip
    bullConf -= amd_manipPenalty
    bearConf -= amd_manipPenalty

// Mid-range penalty
if inMidRange
    bullConf -= 2
    bearConf -= 2

// Correlation divergence penalty
if tog_corr and corrDivergence
    bullConf -= 2
    bearConf -= 2

// Clamp
bullConf := math.max(bullConf, 0)
bearConf := math.max(bearConf, 0)

// ── Apply Day-of-Week weight ──
bullConfWeighted = math.round(bullConf * dowWeight)
bearConfWeighted = math.round(bearConf * dowWeight)

// Use weighted for signal firing, raw for display
bullConfFinal = tog_dow ? bullConfWeighted : bullConf
bearConfFinal = tog_dow ? bearConfWeighted : bearConf

// ── Probability calculation ──
maxPossibleConf = 0
maxPossibleConf += tog_ms ? 1 : 0
maxPossibleConf += tog_choch ? 2 : 0
maxPossibleConf += tog_disp ? 2 : 0
maxPossibleConf += tog_sweep ? 3 : 0
maxPossibleConf += tog_vwap ? 1 : 0
maxPossibleConf += tog_ema ? 1 : 0
maxPossibleConf += tog_sma ? 1 : 0
maxPossibleConf += tog_htf ? 1 : 0
maxPossibleConf += tog_delta ? 1 : 0
maxPossibleConf += tog_rvol ? 1 : 0
maxPossibleConf += tog_midnight ? 1 : 0
maxPossibleConf += tog_pd ? 1 : 0
maxPossibleConf += tog_trapped ? 2 : 0
maxPossibleConf += tog_htfSweep ? 2 : 0
maxPossibleConf += tog_poc ? 1 : 0
maxPossibleConf += tog_exp ? 2 : 0
// NEW max possible additions
maxPossibleConf += tog_ob ? 2 : 0
maxPossibleConf += tog_breaker ? 2 : 0
maxPossibleConf += tog_eql ? 2 : 0
maxPossibleConf += tog_vpa ? 2 : 0
maxPossibleConf += tog_avwap ? 1 : 0
maxPossibleConf += tog_squeeze ? 3 : 0
maxPossibleConf += tog_adr ? 1 : 0

maxPossibleConf := math.max(maxPossibleConf, 1)

bullProb = math.min(math.round(bullConfFinal / maxPossibleConf * 100), 95)
bearProb = math.min(math.round(bearConfFinal / maxPossibleConf * 100), 95)

// ── Signal firing ──
inAnySession = inAsia or inLDN or inNY or inNYPM
sessionAllowed = not trade_sessOnly or inAnySession

// ── OPT4: Squeeze Priority Trigger ──
// When a high-probability squeeze fires, lower the confluence bar from 6→4.
// Rationale: Squeeze alone holds +1.00R OOS on NQ (PF=3.0). The regime change
// is strong enough signal to compensate for fewer confluence factors.
sqPriority = sqBullFire or sqBearFire
minRequired = sqPriority ? 4 : sig_minConf

bullTrigger = bullConfFinal >= minRequired and bullProb >= sig_minProb and not inMidRange and sessionAllowed
bearTrigger = bearConfFinal >= minRequired and bearProb >= sig_minProb and not inMidRange and sessionAllowed

bullSignalRaw = bullTrigger and not bullTrigger[1]
bearSignalRaw = bearTrigger and not bearTrigger[1]

// ── Trade Cooldown (NQ OPT3: 6 bars = 30min prevents revenge re-entries) ──
var int lastTradeBar = 0
cooldownOk = (bar_index - lastTradeBar) >= strat_cooldown

bullSignal = bullSignalRaw and cooldownOk
bearSignal = bearSignalRaw and cooldownOk

if bullSignal or bearSignal
    lastTradeBar := bar_index

// Signal + SL/TP chart labels removed — all info shown in Trade Status panel and main dashboard


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  16. MASTER DASHBOARD (EXPANDED)                                        ║
// ╚══════════════════════════════════════════════════════════════════════════╝

var table dash = table.new(position.top_right, 2, 28, bgcolor=color.new(#0D0D0D, 5), border_color=color.new(#333333, 0), border_width=1)

if barstate.islast
    row = 0

    table.cell(dash, 0, row, "  EM-FSE v6.0 MSE  ", text_color=color.white, text_size=size.small, bgcolor=color.new(#2196F3, 20))
    table.merge_cells(dash, 0, row, 1, row)
    row += 1

    table.cell(dash, 0, row, " BIAS", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, row, biasDir, text_color=biasClr, text_size=size.tiny, bgcolor=color.new(biasClr, 90))
    row += 1

    probTxt = bullProb > bearProb ? str.tostring(bullProb) + "% BULL" : bearProb > bullProb ? str.tostring(bearProb) + "% BEAR" : "FLAT"
    probClr = bullProb > bearProb ? ms_bullClr : bearProb > bullProb ? ms_bearClr : color.gray
    table.cell(dash, 0, row, " Probability", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, row, probTxt, text_color=probClr, text_size=size.tiny)
    row += 1

    table.cell(dash, 0, row, " Structure", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, row, msTrend == 1 ? "BULLISH" : "BEARISH", text_color=msTrend == 1 ? ms_bullClr : ms_bearClr, text_size=size.tiny)
    row += 1

    table.cell(dash, 0, row, " HTF Bias", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, row, htfBull ? "BULL" : htfBear ? "BEAR" : "NEUTRAL", text_color=htfBull ? ms_bullClr : ms_bearClr, text_size=size.tiny)
    row += 1

    htfSweepTxt = htfBuySweepFlag ? "BUYSIDE SWEPT" : htfSellSweepFlag ? "SELLSIDE SWEPT" : "NONE"
    htfSweepClr = htfBuySweepFlag ? ms_bearClr : htfSellSweepFlag ? ms_bullClr : color.gray
    table.cell(dash, 0, row, " HTF LQ Sweep", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, row, htfSweepTxt, text_color=htfSweepClr, text_size=size.tiny)
    row += 1

    pdTxt = inMidRange ? "MID-RANGE" : inPremium ? "PREMIUM" : "DISCOUNT"
    pdClr = inMidRange ? color.new(#9E9E9E, 0) : inPremium ? ms_bearClr : ms_bullClr
    table.cell(dash, 0, row, " P/D Zone", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, row, pdTxt, text_color=pdClr, text_size=size.tiny)
    row += 1

    table.cell(dash, 0, row, " vs VWAP", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, row, close > vwapVal ? "ABOVE" : "BELOW", text_color=close > vwapVal ? ms_bullClr : ms_bearClr, text_size=size.tiny)
    row += 1

    moTxt = na(midnightOpen) ? "N/A" : close > midnightOpen ? "ABOVE" : "BELOW"
    moClr = na(midnightOpen) ? color.gray : close > midnightOpen ? ms_bullClr : ms_bearClr
    table.cell(dash, 0, row, " vs MidOpen", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, row, moTxt, text_color=moClr, text_size=size.tiny)
    row += 1

    pocTxt = na(pocLevel) ? "N/A" : str.tostring(pocLevel, format.mintick)
    table.cell(dash, 0, row, " POC", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, row, pocTxt, text_color=mp_pocClr, text_size=size.tiny)
    row += 1

    table.cell(dash, 0, row, " RVOL", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, row, str.tostring(rvolRatio, "#.##") + "x", text_color=rvolHigh ? color.lime : color.gray, text_size=size.tiny)
    row += 1

    table.cell(dash, 0, row, " Delta", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, row, (deltaApx > 0 ? "+" : "") + str.tostring(deltaApx, "#"), text_color=deltaApx > 0 ? ms_bullClr : ms_bearClr, text_size=size.tiny)
    row += 1

    table.cell(dash, 0, row, " CumDelta", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, row, (cumDelta > 0 ? "+" : "") + str.tostring(cumDelta, "#"), text_color=cumDelta > 0 ? ms_bullClr : ms_bearClr, text_size=size.tiny)
    row += 1

    table.cell(dash, 0, row, " Consolidation", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, row, isConsolidating ? "YES" : "NO", text_color=isConsolidating ? color.new(#FF9800, 0) : color.gray, text_size=size.tiny)
    row += 1

    trapTxt = trappedLongs ? "LONGS TRAPPED" : trappedShorts ? "SHORTS TRAPPED" : "NONE"
    trapClr = trappedLongs ? ms_bearClr : trappedShorts ? ms_bullClr : color.gray
    table.cell(dash, 0, row, " Trapped Flow", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, row, trapTxt, text_color=trapClr, text_size=size.tiny)
    row += 1

    table.cell(dash, 0, row, " ATR", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, row, str.tostring(atrVal, format.mintick), text_color=color.white, text_size=size.tiny)
    row += 1

    // ── NEW Master Swing Dashboard Rows ──
    table.cell(dash, 0, row, " ── SWING ──", text_color=color.new(#FF9800, 0), text_size=size.tiny, bgcolor=color.new(#FF9800, 90))
    table.merge_cells(dash, 0, row, 1, row)
    row += 1

    obTxt = nearBullOB ? "BULL OB" : nearBearOB ? "BEAR OB" : nearBullBreaker ? "BULL BRK" : nearBearBreaker ? "BEAR BRK" : "NONE"
    obClr = nearBullOB or nearBullBreaker ? ms_bullClr : nearBearOB or nearBearBreaker ? ms_bearClr : color.gray
    table.cell(dash, 0, row, " OB/Breaker", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, row, obTxt, text_color=obClr, text_size=size.tiny)
    row += 1

    eqlTxt = eqlHighsDetected and eqlLowsDetected ? "EQH + EQL" : eqlHighsDetected ? "EQ HIGHS" : eqlLowsDetected ? "EQ LOWS" : "NONE"
    table.cell(dash, 0, row, " Equal H/L", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, row, eqlTxt, text_color=eqlHighsDetected or eqlLowsDetected ? eql_hiClr : color.gray, text_size=size.tiny)
    row += 1

    adrTxt = adr_exhausted ? "EXHAUSTED " + str.tostring(adr_pctUsed, "#") + "%" : str.tostring(adr_pctUsed, "#") + "% used"
    adrClr = adr_exhausted ? ms_bearClr : adr_fresh ? ms_bullClr : color.gray
    table.cell(dash, 0, row, " ADR", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, row, adrTxt, text_color=adrClr, text_size=size.tiny)
    row += 1

    vpaTxt = vpa_bullAbsorb ? "BUY ABSORBED" : vpa_bearAbsorb ? "SELL ABSORBED" : vpa_absorption ? "ABSORBING" : "NORMAL"
    vpaClr = vpa_bullAbsorb ? ms_bearClr : vpa_bearAbsorb ? ms_bullClr : vpa_absorption ? color.new(#9C27B0, 0) : color.gray
    table.cell(dash, 0, row, " VPA", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, row, vpaTxt, text_color=vpaClr, text_size=size.tiny)
    row += 1

    sqTxt = sqOn ? "SQUEEZE ON" : sqBullFire ? "FIRED BULL" : sqBearFire ? "FIRED BEAR" : "OFF"
    sqClr = sqOn ? color.new(#FF5722, 0) : sqBullFire ? ms_bullClr : sqBearFire ? ms_bearClr : color.gray
    table.cell(dash, 0, row, " Squeeze", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, row, sqTxt, text_color=sqClr, text_size=size.tiny)
    row += 1

    amdTxt = amd_inManip ? "MANIPULATION" : "DISTRIBUTION"
    amdClr = amd_inManip ? color.new(#FF5722, 0) : color.gray
    table.cell(dash, 0, row, " AMD Phase", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, row, amdTxt, text_color=amdClr, text_size=size.tiny)
    row += 1

    dowTxt = dow == dayofweek.monday ? "MON " : dow == dayofweek.tuesday ? "TUE " : dow == dayofweek.wednesday ? "WED " : dow == dayofweek.thursday ? "THU " : "FRI "
    dowTxt += str.tostring(dowWeight, "#.#") + "x"
    table.cell(dash, 0, row, " DOW Weight", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, row, dowTxt, text_color=dowWeight >= 1.0 ? ms_bullClr : color.new(#FF9800, 0), text_size=size.tiny)
    row += 1

    if corr_enable
        corrTxt = corrDivergence ? "DIVERGING " + str.tostring(corrVal, "#.##") : "ALIGNED " + str.tostring(nz(corrVal, 0), "#.##")
        corrClr2 = corrDivergence ? ms_bearClr : ms_bullClr
        table.cell(dash, 0, row, " ES/NQ Corr", text_color=color.gray, text_size=size.tiny)
        table.cell(dash, 1, row, corrTxt, text_color=corrClr2, text_size=size.tiny)
        row += 1

    // Confluence scores
    table.cell(dash, 0, row, " Bull Score", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, row, str.tostring(bullConfFinal) + " / " + str.tostring(maxPossibleConf) + (tog_dow ? " (w)" : ""), text_color=bullConfFinal >= sig_minConf ? ms_bullClr : color.gray, text_size=size.tiny)
    row += 1

    table.cell(dash, 0, row, " Bear Score", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, row, str.tostring(bearConfFinal) + " / " + str.tostring(maxPossibleConf) + (tog_dow ? " (w)" : ""), text_color=bearConfFinal >= sig_minConf ? ms_bearClr : color.gray, text_size=size.tiny)
    row += 1

    sessT = inAsia ? "ASIA" : inLDN ? "LONDON" : inNY ? "NY AM" : inNYPM ? "NY PM" : "OFF"
    table.cell(dash, 0, row, " Session", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, row, sessT, text_color=color.white, text_size=size.tiny)
    row += 1


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  16.5 AUTO-TRADING STRATEGY EXECUTION (EXPANDED w/ PARTIAL TP)          ║
// ╚══════════════════════════════════════════════════════════════════════════╝

strategy.risk.max_intraday_loss(prop_dll_en ? prop_dll : 99999999, strategy.cash)
strategy.risk.max_drawdown(prop_maxdd_en ? prop_maxdd : 99999999, strategy.cash)

if strat_enable
    h_est2 = hour(time, "America/New_York")
    m_est2 = minute(time, "America/New_York")

    is_eod_window = (h_est2 == prop_eod_hour and m_est2 >= prop_eod_min)
    if prop_eod_en and is_eod_window
        strategy.close_all(comment="PROP EOD CLOSE", alert_message='{"action": "flatten", "ticker": "NQ"}')

    safe_to_enter = not (prop_eod_en and is_eod_window)

    var float startOfDayEquity = strategy.equity
    if f_isNewDay()
        startOfDayEquity := strategy.equity
    dailyProfit = strategy.equity - startOfDayEquity
    profit_target_hit = prop_target_en and (dailyProfit >= prop_target)

    strat_slAbs = atrVal * atr_stopMult
    sys_riskRisk = strategy.equity * (strat_risk / 100)
    comp_qty = (strat_slAbs > 0 and syminfo.pointvalue > 0) ? (sys_riskRisk / (strat_slAbs * syminfo.pointvalue)) : 0
    final_qty = strat_comp ? math.max(math.floor(comp_qty), 1) : strat_qty

    // Dynamic Liquidity-Targeting
    float tp_long_lvl = close + atrVal * atr_tp1Mult
    bool valid_lq_long = true
    if array.size(lqHighs) > 0
        float bestSqH = 9999999.0
        for i = 0 to array.size(lqHighs) - 1
            lvl = array.get(lqHighs, i)
            if lvl > close and lvl < bestSqH
                bestSqH := lvl
        if bestSqH != 9999999.0
            if (bestSqH - close) < (strat_slAbs * 1.5)
                valid_lq_long := false
            else
                tp_long_lvl := bestSqH

    float tp_short_lvl = close - atrVal * atr_tp1Mult
    bool valid_lq_short = true
    if array.size(lqLows) > 0
        float bestSqL = 0.0
        for i = 0 to array.size(lqLows) - 1
            lvl = array.get(lqLows, i)
            if lvl < close and lvl > bestSqL
                bestSqL := lvl
        if bestSqL != 0.0
            if (close - bestSqL) < (strat_slAbs * 1.5)
                valid_lq_short := false
            else
                tp_short_lvl := bestSqL

    expected_profit_long = (tp_long_lvl - close) * syminfo.pointvalue * final_qty
    isWorthTakingLong = not prop_minwin_en or (expected_profit_long >= prop_minwin)

    expected_profit_short = (close - tp_short_lvl) * syminfo.pointvalue * final_qty
    isWorthTakingShort = not prop_minwin_en or (expected_profit_short >= prop_minwin)

    eval_long  = isWorthTakingLong and (not prop_lq_filter or valid_lq_long)
    eval_short = isWorthTakingShort and (not prop_lq_filter or valid_lq_short)

    // ── Partial TP + Trailing Logic ──
    if partial_enable
        // Long entries: TP1 partial, then trail remainder
        if bullSignal and not profit_target_hit and eval_long and safe_to_enter
            strat_sl = close - atrVal * atr_stopMult
            partial_qty = math.max(math.floor(final_qty * partial_pct / 100), 1)
            remain_qty  = math.max(final_qty - partial_qty, 1)

            // PMT dynamic JSON: embed SL/TP as price levels
            pmt_long_entry = '{"action": "buy", "ticker": "NQ", "qty": ' + str.tostring(final_qty) + ', "sl": ' + str.tostring(math.round(strat_sl * 100) / 100) + ', "tp": ' + str.tostring(math.round(tp_long_lvl * 100) / 100) + '}'
            pmt_long_tp1   = '{"action": "sell", "ticker": "NQ", "qty": ' + str.tostring(partial_qty) + ', "partial": true}'
            pmt_long_trail = '{"action": "sell", "ticker": "NQ", "qty": ' + str.tostring(remain_qty) + ', "trail": true}'

            strategy.entry("Long", strategy.long, qty=final_qty, alert_message=pmt_long_entry)
            // TP1: close partial at first liquidity target
            strategy.exit("TP1 L", "Long", qty=partial_qty, stop=strat_sl, limit=tp_long_lvl, alert_message=pmt_long_tp1)
            // TP2: trail remainder using ATR-based trailing stop
            tp2_lvl = close + atrVal * atr_tp2Mult
            trail_offset = math.round(atrVal * trail_atrMult / syminfo.mintick)
            strategy.exit("Trail L", "Long", qty=remain_qty, stop=strat_sl, trail_price=tp_long_lvl, trail_offset=trail_offset, alert_message=pmt_long_trail)

        if bearSignal and not profit_target_hit and eval_short and safe_to_enter
            strat_sl = close + atrVal * atr_stopMult
            partial_qty = math.max(math.floor(final_qty * partial_pct / 100), 1)
            remain_qty  = math.max(final_qty - partial_qty, 1)

            // PMT dynamic JSON: embed SL/TP as price levels
            pmt_short_entry = '{"action": "sell", "ticker": "NQ", "qty": ' + str.tostring(final_qty) + ', "sl": ' + str.tostring(math.round(strat_sl * 100) / 100) + ', "tp": ' + str.tostring(math.round(tp_short_lvl * 100) / 100) + '}'
            pmt_short_tp1   = '{"action": "buy", "ticker": "NQ", "qty": ' + str.tostring(partial_qty) + ', "partial": true}'
            pmt_short_trail = '{"action": "buy", "ticker": "NQ", "qty": ' + str.tostring(remain_qty) + ', "trail": true}'

            strategy.entry("Short", strategy.short, qty=final_qty, alert_message=pmt_short_entry)
            strategy.exit("TP1 S", "Short", qty=partial_qty, stop=strat_sl, limit=tp_short_lvl, alert_message=pmt_short_tp1)
            tp2_lvl = close - atrVal * atr_tp2Mult
            trail_offset = math.round(atrVal * trail_atrMult / syminfo.mintick)
            strategy.exit("Trail S", "Short", qty=remain_qty, stop=strat_sl, trail_price=tp_short_lvl, trail_offset=trail_offset, alert_message=pmt_short_trail)

    else
        // Original binary exit logic
        if bullSignal and not profit_target_hit and eval_long and safe_to_enter
            strat_sl = close - atrVal * atr_stopMult
            strat_tp = tp_long_lvl
            pmt_long_msg = '{"action": "buy", "ticker": "NQ", "qty": ' + str.tostring(final_qty) + ', "sl": ' + str.tostring(math.round(strat_sl * 100) / 100) + ', "tp": ' + str.tostring(math.round(strat_tp * 100) / 100) + '}'
            pmt_long_exit = '{"action": "sell", "ticker": "NQ", "qty": ' + str.tostring(final_qty) + '}'
            strategy.entry("Long", strategy.long, qty=final_qty, alert_message=pmt_long_msg)
            strategy.exit("Exit L", "Long", stop=strat_sl, limit=strat_tp, alert_message=pmt_long_exit)
        if bearSignal and not profit_target_hit and eval_short and safe_to_enter
            strat_sl = close + atrVal * atr_stopMult
            strat_tp = tp_short_lvl
            pmt_short_msg = '{"action": "sell", "ticker": "NQ", "qty": ' + str.tostring(final_qty) + ', "sl": ' + str.tostring(math.round(strat_sl * 100) / 100) + ', "tp": ' + str.tostring(math.round(strat_tp * 100) / 100) + '}'
            pmt_short_exit = '{"action": "buy", "ticker": "NQ", "qty": ' + str.tostring(final_qty) + '}'
            strategy.entry("Short", strategy.short, qty=final_qty, alert_message=pmt_short_msg)
            strategy.exit("Exit S", "Short", stop=strat_sl, limit=strat_tp, alert_message=pmt_short_exit)


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  17. TRADE STATUS PANEL                                                  ║
// ║  Shows: ENTER NOW / WAIT / TIME PASSED + TP1, TP2, Stop Loss            ║
// ╚══════════════════════════════════════════════════════════════════════════╝

// ── Persistent state — captured on every new signal ──────────────────────────
var float  ts_entry  = na
var float  ts_sl     = na
var float  ts_tp1    = na
var float  ts_tp2    = na
var int    ts_sigBar = na
var int    ts_dir    = 0   // 1 = long, -1 = short

if bullSignal
    ts_entry  := close
    ts_sl     := close - atrVal * atr_stopMult
    ts_tp1    := close + atrVal * atr_tp1Mult
    ts_tp2    := close + atrVal * atr_tp2Mult
    ts_sigBar := bar_index
    ts_dir    := 1

if bearSignal
    ts_entry  := close
    ts_sl     := close + atrVal * atr_stopMult
    ts_tp1    := close - atrVal * atr_tp1Mult
    ts_tp2    := close - atrVal * atr_tp2Mult
    ts_sigBar := bar_index
    ts_dir    := -1

// ── Derived values ────────────────────────────────────────────────────────────
ts_barsAgo   = na(ts_sigBar) ? 999 : bar_index - ts_sigBar
ts_inPos     = strategy.position_size != 0
ts_isLong    = strategy.position_size > 0

// Live entry price: use open trade price when in position, else last signal price
ts_liveEntry = ts_inPos and strategy.opentrades > 0 ? strategy.opentrades.entry_price(0) : ts_entry

// Points distances
ts_riskPts = not na(ts_liveEntry) and not na(ts_sl)  ? math.abs(ts_liveEntry - ts_sl)  : na
ts_tp1Pts  = not na(ts_liveEntry) and not na(ts_tp1) ? math.abs(ts_tp1 - ts_liveEntry) : na
ts_tp2Pts  = not na(ts_liveEntry) and not na(ts_tp2) ? math.abs(ts_tp2 - ts_liveEntry) : na

// Live P&L in points and R (sign-corrected for direction)
ts_pnlDir   = ts_inPos ? (ts_isLong ? 1.0 : -1.0) : float(ts_dir)
ts_curPnl   = ts_inPos and not na(ts_liveEntry) ? (close - ts_liveEntry) * ts_pnlDir : na
ts_curR     = not na(ts_curPnl) and not na(ts_riskPts) and ts_riskPts > 0 ? ts_curPnl / ts_riskPts : na

// ── Status text & colour ──────────────────────────────────────────────────────
ts_statusTxt =
     ts_inPos           ? (ts_isLong ? "▶  IN TRADE  ↑  LONG"  : "▶  IN TRADE  ↓  SHORT")
   : ts_barsAgo == 0    ? "⚡ ENTER NOW"
   : ts_barsAgo <= 3    ? "⏳ WAIT  (" + str.tostring(ts_barsAgo) + " bars ago)"
   : na(ts_sigBar)      ? "— NO SIGNAL YET —"
   : "⌛ TIME PASSED  (" + str.tostring(ts_barsAgo) + " bars ago)"

ts_statusClr =
     ts_inPos           ? (ts_isLong ? ms_bullClr : ms_bearClr)
   : ts_barsAgo == 0    ? color.new(#00E676, 0)
   : ts_barsAgo <= 3    ? color.new(#FF9800, 0)
   : color.new(#607D8B, 0)

ts_hdrBg =
     ts_inPos           ? (ts_isLong ? color.new(#004D40, 20) : color.new(#4A0000, 20))
   : ts_barsAgo == 0    ? color.new(#1B5E20, 20)
   : ts_barsAgo <= 3    ? color.new(#E65100, 30)
   : color.new(#1A237E, 20)

// ── Panel definition ──────────────────────────────────────────────────────────
var table ts_panel = table.new(
     position.bottom_left, 2, 10,
     bgcolor        = color.new(#0A0A0A, 5),
     border_color   = color.new(#444444, 0),
     border_width   = 1,
     frame_color    = color.new(#2196F3, 0),
     frame_width    = 2)

if barstate.islast

    // Row 0 — header
    table.cell(ts_panel, 0, 0, "  TRADE STATUS  ",
         text_color=color.white, text_size=size.small, bgcolor=ts_hdrBg)
    table.merge_cells(ts_panel, 0, 0, 1, 0)

    // Row 1 — status
    table.cell(ts_panel, 0, 1, "  " + ts_statusTxt + "  ",
         text_color=ts_statusClr, text_size=size.small,
         bgcolor=color.new(ts_statusClr, 88))
    table.merge_cells(ts_panel, 0, 1, 1, 1)

    if not na(ts_entry)

        // Row 2 — direction
        dirClr = ts_dir == 1 ? ms_bullClr : ms_bearClr
        dirTxt = ts_dir == 1 ? "↑  LONG" : "↓  SHORT"
        table.cell(ts_panel, 0, 2, " Direction",   text_color=color.gray,   text_size=size.tiny)
        table.cell(ts_panel, 1, 2, dirTxt,         text_color=dirClr,       text_size=size.small)

        // Row 3 — entry
        table.cell(ts_panel, 0, 3, " Entry",       text_color=color.gray,   text_size=size.tiny)
        table.cell(ts_panel, 1, 3, str.tostring(ts_liveEntry, format.mintick),
             text_color=color.white, text_size=size.small)

        // Row 4 — TP1
        tp1Str = str.tostring(ts_tp1, format.mintick) +
             (not na(ts_tp1Pts) ? "   (+" + str.tostring(ts_tp1Pts, "#.0") + " pts)" : "")
        table.cell(ts_panel, 0, 4, " TP1",         text_color=color.gray,   text_size=size.tiny)
        table.cell(ts_panel, 1, 4, tp1Str,         text_color=ms_bullClr,   text_size=size.small)

        // Row 5 — TP2
        tp2Str = str.tostring(ts_tp2, format.mintick) +
             (not na(ts_tp2Pts) ? "   (+" + str.tostring(ts_tp2Pts, "#.0") + " pts)" : "")
        table.cell(ts_panel, 0, 5, " TP2",         text_color=color.gray,   text_size=size.tiny)
        table.cell(ts_panel, 1, 5, tp2Str,         text_color=color.new(#4CAF50, 0), text_size=size.small)

        // Row 6 — stop loss
        slStr = str.tostring(ts_sl, format.mintick) +
             (not na(ts_riskPts) ? "   (–" + str.tostring(ts_riskPts, "#.0") + " pts)" : "")
        table.cell(ts_panel, 0, 6, " Stop Loss",   text_color=color.gray,   text_size=size.tiny)
        table.cell(ts_panel, 1, 6, slStr,          text_color=ms_bearClr,   text_size=size.small)

        // Row 7 — R:R ratio
        if not na(ts_tp1Pts) and not na(ts_riskPts) and ts_riskPts > 0
            rrTP1 = ts_tp1Pts / ts_riskPts
            rrTP2 = not na(ts_tp2Pts) ? ts_tp2Pts / ts_riskPts : 0.0
            rrTxt = "1 : " + str.tostring(rrTP1, "#.##") +
                 "  │  TP2: 1 : " + str.tostring(rrTP2, "#.##")
            table.cell(ts_panel, 0, 7, " R:R",     text_color=color.gray,   text_size=size.tiny)
            table.cell(ts_panel, 1, 7, rrTxt,      text_color=color.white,  text_size=size.tiny)

        // Row 8 — live P&L (only when position is open)
        if ts_inPos and not na(ts_curR)
            pnlSign = ts_curPnl >= 0 ? "+" : ""
            pnlClr  = ts_curPnl >= 0 ? ms_bullClr : ms_bearClr
            pnlTxt  = pnlSign + str.tostring(ts_curPnl, "#.0") +
                 " pts   " + pnlSign + str.tostring(ts_curR, "#.##") + "R"
            table.cell(ts_panel, 0, 8, " Live P&L", text_color=color.gray,  text_size=size.tiny)
            table.cell(ts_panel, 1, 8, pnlTxt,      text_color=pnlClr,     text_size=size.small)

    else
        table.cell(ts_panel, 0, 2, "  Waiting for first signal…",
             text_color=color.new(#607D8B, 0), text_size=size.tiny,
             bgcolor=color.new(#0A0A0A, 0))
        table.merge_cells(ts_panel, 0, 2, 1, 2)


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  18. BRIDGE HANDSHAKE — PMT Price Variables                              ║
// ║  Publishes SL/TP as plot streams so Pick My Trade can reference them     ║
// ║  via {{plot("SL_Price")}} and {{plot("TP_Price")}} in alert config.      ║
// ╚══════════════════════════════════════════════════════════════════════════╝

plot(ts_sl,  "SL_Price", display=display.none)
plot(ts_tp1, "TP_Price", display=display.none)

