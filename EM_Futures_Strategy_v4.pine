// ============================================================================
// EM FUTURES STRATEGY v3.0
// © Edwin Maina — Designed for ES / NQ Futures
// ICT + Smart Money Confluence Engine
// Copy this entire script into TradingView Pine Editor > Add to Chart
// ============================================================================

//@version=6
strategy("EM Futures Strategy v4.0", shorttitle="EM-FSE Strat 4.0", overlay=true, initial_capital=10000, margin_long=5, margin_short=5, default_qty_type=strategy.fixed, default_qty_value=1, calc_on_every_tick=true, max_boxes_count=500, max_lines_count=500, max_labels_count=500, max_bars_back=5000)


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  INPUTS                                                                 ║
// ╚══════════════════════════════════════════════════════════════════════════╝

// ── Market Structure ──
grpMS         = "① Market Structure"
ms_enable     = input.bool(true, "Enable Market Structure", group=grpMS)
ms_length     = input.int(5, "Swing Lookback", minval=2, maxval=50, group=grpMS)
ms_showBOS    = input.bool(true, "Show BOS", group=grpMS)
ms_showCHoCH  = input.bool(true, "Show CHoCH", group=grpMS)
ms_bullClr    = input.color(color.new(#00E676, 0), "Bullish", group=grpMS)
ms_bearClr    = input.color(color.new(#FF5252, 0), "Bearish", group=grpMS)

// ── Liquidity Pools ──
grpLQ         = "② Liquidity Pools & Sweeps"
lq_enable     = input.bool(true, "Enable Liquidity Detection", group=grpLQ)
lq_swingLen   = input.int(10, "Liquidity Swing Length", minval=3, maxval=50, group=grpLQ)
lq_sweepWick  = input.float(0.3, "Min Wick Ratio for Sweep", step=0.05, group=grpLQ, tooltip="Wick must be this fraction of total range to qualify as sweep")
lq_poolClr    = input.color(color.new(#FFEB3B, 50), "Liquidity Pool", group=grpLQ)
lq_sweepClr   = input.color(color.new(#E040FB, 0), "Sweep Marker", group=grpLQ)
lq_maxPools   = input.int(20, "Max Pool Lines", minval=5, maxval=50, group=grpLQ)

// ── Fair Value Gaps ──
grpFVG        = "③ Fair Value Gaps (PD Arrays)"
fvg_enable    = input.bool(true, "Enable FVG", group=grpFVG)
fvg_bullClr   = input.color(color.new(#00E676, 82), "Bullish FVG", group=grpFVG)
fvg_bearClr   = input.color(color.new(#FF5252, 82), "Bearish FVG", group=grpFVG)
fvg_oppClr    = input.color(color.new(#FF9800, 60), "Opposing PD Array", group=grpFVG)
fvg_maxBoxes  = input.int(15, "Max FVG Boxes", minval=1, maxval=50, group=grpFVG)
fvg_minATR    = input.float(0.3, "Min FVG Size (ATR mult)", step=0.1, group=grpFVG)
fvg_mitigate  = input.bool(true, "Remove Mitigated", group=grpFVG)

// ── Displacement ──
grpDisp       = "④ Displacement (Phase Change)"
disp_enable   = input.bool(true, "Enable Displacement", group=grpDisp)
disp_atrMult  = input.float(2.0, "ATR Multiple", step=0.1, group=grpDisp)
disp_atrLen   = input.int(14, "ATR Length", group=grpDisp)

// ── Consolidation & Expansion ──
grpCE         = "⑤ Consolidation → Expansion"
ce_enable     = input.bool(true, "Enable Consolidation Detection", group=grpCE)
ce_lookback   = input.int(20, "Consolidation Lookback Bars", minval=5, maxval=100, group=grpCE)
ce_atrRatio   = input.float(0.5, "ATR Compression Ratio", step=0.05, group=grpCE, tooltip="Current range / ATR below this = consolidation")
ce_expMult    = input.float(1.5, "Expansion ATR Multiple", step=0.1, group=grpCE, tooltip="Candle body > this * ATR = expansion")
ce_boxClr     = input.color(color.new(#9E9E9E, 85), "Consolidation Zone", group=grpCE)

// ── Key Levels ──
grpLV         = "⑥ Key Levels (PDH/PDL/MO/Weekly)"
lv_enable     = input.bool(true, "Enable Key Levels", group=grpLV)
lv_pdHL       = input.bool(true, "PDH / PDL", group=grpLV)
lv_pdClose    = input.bool(true, "Prior Day Close", group=grpLV)
lv_midOpen    = input.bool(true, "Midnight Open (00:00 EST)", group=grpLV)
lv_weekHL     = input.bool(true, "Prior Week H/L", group=grpLV)
lv_pdhClr     = input.color(color.new(#FF9800, 0), "PDH/PDL", group=grpLV)
lv_pdcClr     = input.color(color.new(#9C27B0, 0), "PDC", group=grpLV)
lv_midClr     = input.color(color.new(#00BCD4, 0), "Midnight Open", group=grpLV)
lv_wkClr      = input.color(color.new(#FFEB3B, 30), "Weekly H/L", group=grpLV)

// ── Sessions ──
grpSess       = "⑦ Sessions"
sess_enable   = input.bool(true, "Enable Sessions", group=grpSess)
sess_asia     = input.bool(true, "Asia (20:00-00:00 EST)", group=grpSess)
sess_ldn      = input.bool(true, "London (02:00-05:00 EST)", group=grpSess)
sess_nyAM     = input.bool(true, "NY AM (09:30-12:00 EST)", group=grpSess)
sess_nyPM     = input.bool(true, "NY PM (13:30-16:00 EST)", group=grpSess)
trade_sessOnly = input.bool(true, "📌 Restrict Trading to Active Sessions", group=grpSess, tooltip="If checked, the strategy will NOT take trades in the 'dead zones' outside of the sessions selected above. Eliminates lunchtime and overnight chop.")
sess_asiaClr  = input.color(color.new(#E040FB, 93), "Asia", group=grpSess)
sess_ldnClr   = input.color(color.new(#448AFF, 93), "London", group=grpSess)
sess_nyClr    = input.color(color.new(#FF9800, 93), "NY AM", group=grpSess)
sess_nypmClr  = input.color(color.new(#795548, 93), "NY PM", group=grpSess)

// ── VWAP ──
grpVWAP       = "⑧ VWAP & Bands"
vwap_enable   = input.bool(true, "Enable VWAP", group=grpVWAP)
vwap_bands    = input.bool(true, "Show StdDev Bands", group=grpVWAP)
vwap_m1       = input.float(1.0, "Band 1 StdDev", step=0.25, group=grpVWAP)
vwap_m2       = input.float(2.0, "Band 2 StdDev", step=0.25, group=grpVWAP)
vwap_clr      = input.color(color.new(#2196F3, 0), "VWAP Color", group=grpVWAP)

// ── Order Flow & Delta ──
grpOF         = "⑨ Order Flow & Delta"
of_enable     = input.bool(true, "Enable Order Flow Analysis", group=grpOF)
of_trapped    = input.bool(true, "Detect Trapped Traders", group=grpOF)
of_rvolLen    = input.int(20, "RVOL Lookback", group=grpOF)
of_rvolThresh = input.float(1.5, "RVOL Threshold", step=0.1, group=grpOF)

// ── Moving Averages ──
grpMA         = "⑩ Moving Averages"
ma_enable     = input.bool(true, "Enable MAs", group=grpMA)
ma_fastLen    = input.int(9, "Fast EMA", group=grpMA)
ma_slowLen    = input.int(21, "Slow EMA", group=grpMA)
ma_trendLen   = input.int(200, "Trend SMA", group=grpMA)
ma_fastClr    = input.color(color.new(#00E676, 0), "Fast", group=grpMA)
ma_slowClr    = input.color(color.new(#FF5252, 0), "Slow", group=grpMA)
ma_trendClr   = input.color(color.new(#FFFFFF, 50), "Trend", group=grpMA)

// ── HTF Confirmation ──
grpHTF        = "⑪ Higher Timeframe"
htf_enable    = input.bool(true, "Enable HTF Filter", group=grpHTF)
htf_tf        = input.timeframe("60", "HTF Timeframe", group=grpHTF)
htf_emaLen    = input.int(21, "HTF EMA Length", group=grpHTF)
htf_swingLen  = input.int(10, "HTF Swing Length", group=grpHTF)

// ── Market Profile ──
grpMP         = "⑫ Market Profile"
mp_enable     = input.bool(true, "Enable Market Profile", group=grpMP)
mp_len        = input.int(50, "Profile Lookback Bars", minval=10, maxval=200, group=grpMP)
mp_rows       = input.int(24, "Price Rows", minval=10, maxval=50, group=grpMP)
mp_pocClr     = input.color(color.new(#FFEB3B, 0), "POC Color", group=grpMP)
mp_vaClr      = input.color(color.new(#2196F3, 85), "Value Area Fill", group=grpMP)

// ── ATR Stops & Targets ──
grpATR        = "⑬ ATR Stops & Targets"
atr_enable    = input.bool(true, "Enable ATR Zones", group=grpATR)
atr_length    = input.int(14, "ATR Period", group=grpATR)
atr_stopMult  = input.float(1.0, "SL ATR Multiple", step=0.1, group=grpATR)
atr_tp1Mult   = input.float(3.0, "TP1 ATR Multiple", step=0.1, group=grpATR)
atr_tp2Mult   = input.float(3.0, "TP2 ATR Multiple", step=0.1, group=grpATR)

// ── Signal Engine ──
grpSig        = "⑭ Signal & Probability Engine"
sig_minConf   = input.int(4, "Min Confluence for Signal", minval=1, maxval=15, group=grpSig)
sig_minProb   = input.int(25, "Minimum Certainty (%)", minval=0, maxval=100, group=grpSig, tooltip="Warning: Values above 30% are highly restrictive since signals depend on instant, single-bar events (like CHoCH/Sweeps) overlapping exactly.")

// ── ICT Time Models ──
grpICT        = "⑮ ICT Time Models"
ict_enable    = input.bool(true, "Enable ICT Time Models", group=grpICT)
ict_sb_am     = input.bool(true, "Silver Bullet AM (10:00-11:00)", group=grpICT)
ict_sb_pm     = input.bool(true, "Silver Bullet PM (14:00-15:00)", group=grpICT)
ict_macros    = input.bool(true, "ICT Macros (e.g. 09:50-10:10)", group=grpICT)

// ── Strategy Configuration ──
grpStrat      = "⑯ Strategy Execution"
strat_enable  = input.bool(true, "Enable Strategy Mode", group=grpStrat)
strat_comp    = input.bool(true,  "📈 Enable Compounding (Risk %)", group=grpStrat, tooltip="Scales contracts dynamically as account equity grows (Exponential Curve). Uncheck to use Fixed Size (Linear Curve).")
strat_risk    = input.float(1.0, "Risk % per Trade", step=0.1, group=grpStrat)
strat_qty     = input.float(1, "Fixed Position Size (Contracts)", group=grpStrat)
webhook_buy   = input.string('{"action": "buy", "ticker": "{{ticker}}", "qty": 1}', "Buy Alert JSON", group=grpStrat)
webhook_sell  = input.string('{"action": "sell", "ticker": "{{ticker}}", "qty": 1}', "Sell Alert JSON", group=grpStrat)



// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  UTILITIES                                                              ║
// ╚══════════════════════════════════════════════════════════════════════════╝

f_isNewDay()  => ta.change(time("D")) != 0
f_isNewWeek() => ta.change(time("W")) != 0

f_inSession(startH, endH) =>
    h = hour(time, "America/New_York")
    h >= startH and h < endH

f_isIctMacro() =>
    h = hour(time, "America/New_York")
    m = minute(time, "America/New_York")
    (h == 9 and m >= 50) or (h == 10 and m < 10) or
      (h == 10 and m >= 50) or (h == 11 and m < 10) or
      (h == 11 and m >= 50) or (h == 12 and m < 10) or
      (h == 13 and m >= 50) or (h == 14 and m < 10) or
      (h == 14 and m >= 50) or (h == 15 and m < 10) or
      (h == 15 and m >= 50)

f_isSilverBullet() =>
    h = hour(time, "America/New_York")
    (ict_sb_am and h == 10) or (ict_sb_pm and h == 14)


f_wickRatioTop(o, h, l, c) =>
    rng = h - l
    rng > 0 ? (h - math.max(o, c)) / rng : 0.0

f_wickRatioBot(o, h, l, c) =>
    rng = h - l
    rng > 0 ? (math.min(o, c) - l) / rng : 0.0

atrGlobal = ta.atr(14)


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  1. MARKET STRUCTURE — BOS / CHoCH                                      ║
// ╚══════════════════════════════════════════════════════════════════════════╝

var float msSwH = na, var float msSwL = na
var int msTrend = 0

pivHi = ta.pivothigh(high, ms_length, ms_length)
pivLo = ta.pivotlow(low, ms_length, ms_length)

var bool bosUp = false, var bool bosDn = false
var bool chochUp = false, var bool chochDn = false
bosUp := false
bosDn := false
chochUp := false
chochDn := false

if ms_enable
    if not na(pivHi)
        msSwH := pivHi
    if not na(pivLo)
        msSwL := pivLo
    if msTrend == 0
        msTrend := close > open ? 1 : -1
    // BOS = continuation break
    if not na(msSwH) and close > msSwH and msTrend == 1
        bosUp := true
    if not na(msSwL) and close < msSwL and msTrend == -1
        bosDn := true
    // CHoCH = reversal break
    if not na(msSwH) and close > msSwH and msTrend == -1
        chochUp := true
        msTrend := 1
    if not na(msSwL) and close < msSwL and msTrend == 1
        chochDn := true
        msTrend := -1

if ms_enable and ms_showBOS and bosUp
    label.new(bar_index, low, "BOS", style=label.style_label_up, color=color.new(ms_bullClr, 50), textcolor=color.white, size=size.tiny)
if ms_enable and ms_showBOS and bosDn
    label.new(bar_index, high, "BOS", style=label.style_label_down, color=color.new(ms_bearClr, 50), textcolor=color.white, size=size.tiny)
if ms_enable and ms_showCHoCH and chochUp
    label.new(bar_index, low, "CHoCH", style=label.style_label_up, color=ms_bullClr, textcolor=color.black, size=size.small)
if ms_enable and ms_showCHoCH and chochDn
    label.new(bar_index, high, "CHoCH", style=label.style_label_down, color=ms_bearClr, textcolor=color.white, size=size.small)
plotshape(ms_enable and ms_showCHoCH and chochDn, "CHoCH↓", shape.diamond, location.abovebar, ms_bearClr, size=size.small, text="CHoCH")


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  2. LIQUIDITY POOLS, SWEEPS & REVERSALS                                ║
// ╚══════════════════════════════════════════════════════════════════════════╝

// Detect swing high/low clusters as liquidity pools
lqPivHi = ta.pivothigh(high, lq_swingLen, lq_swingLen)
lqPivLo = ta.pivotlow(low, lq_swingLen, lq_swingLen)

var float[] lqHighs = array.new<float>()
var int[]   lqHighBars = array.new<int>()
var float[] lqLows  = array.new<float>()
var int[]   lqLowBars = array.new<int>()
var line[]  lqLines = array.new<line>()

// Track liquidity pools
if lq_enable and not na(lqPivHi)
    array.push(lqHighs, lqPivHi)
    array.push(lqHighBars, bar_index - lq_swingLen)
    if array.size(lqHighs) > lq_maxPools
        array.shift(lqHighs)
        array.shift(lqHighBars)

if lq_enable and not na(lqPivLo)
    array.push(lqLows, lqPivLo)
    array.push(lqLowBars, bar_index - lq_swingLen)
    if array.size(lqLows) > lq_maxPools
        array.shift(lqLows)
        array.shift(lqLowBars)

// Detect liquidity sweeps — wick through level, body closes back
var bool lqSweepHigh = false
var bool lqSweepLow  = false
var float lqSweptLevel = na
lqSweepHigh := false
lqSweepLow  := false

if lq_enable
    // Check buyside liquidity sweep (wick above swing high, close below)
    topWickRatio = f_wickRatioTop(open, high, low, close)
    botWickRatio = f_wickRatioBot(open, high, low, close)

    if array.size(lqHighs) > 0
        for i = 0 to array.size(lqHighs) - 1
            lvl = array.get(lqHighs, i)
            if high > lvl and close < lvl and topWickRatio >= lq_sweepWick
                lqSweepHigh := true
                lqSweptLevel := lvl
                break

    if array.size(lqLows) > 0
        for i = 0 to array.size(lqLows) - 1
            lvl = array.get(lqLows, i)
            if low < lvl and close > lvl and botWickRatio >= lq_sweepWick
                lqSweepLow := true
                lqSweptLevel := lvl
                break

// Reversal after sweep: sweep + opposite close
sweepBullReversal = lqSweepLow and close > open
sweepBearReversal = lqSweepHigh and close < open

if lq_enable and sweepBullReversal
    label.new(bar_index, low, "SWEEP REV", style=label.style_label_up, color=color.new(#E040FB, 0), textcolor=color.white, size=size.small)
if lq_enable and sweepBearReversal
    label.new(bar_index, high, "SWEEP REV", style=label.style_label_down, color=color.new(#E040FB, 0), textcolor=color.white, size=size.small)


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  3. FAIR VALUE GAPS + OPPOSING PD ARRAYS                                ║
// ╚══════════════════════════════════════════════════════════════════════════╝

var box[] fvgBoxes = array.new<box>()
var int[] fvgTypes = array.new<int>()  // 1 = bull, -1 = bear

// Premium / Discount zone based on current swing range
swRangeHi = ta.highest(high, 50)
swRangeLo = ta.lowest(low, 50)
equilibrium = (swRangeHi + swRangeLo) / 2.0
inPremium = close > equilibrium
inDiscount = close < equilibrium

if fvg_enable and bar_index > 2
    bullFVG = low > high[2] and (low - high[2]) > atrGlobal * fvg_minATR
    bearFVG = high < low[2] and (low[2] - high) > atrGlobal * fvg_minATR

    if bullFVG
        // Opposing PD array = bullish FVG in premium zone
        isOpposing = inPremium
        clr = isOpposing ? fvg_oppClr : fvg_bullClr
        b = box.new(bar_index - 2, low, bar_index + 30, high[2], bgcolor=clr, border_color=color.new(color.green, 60), border_width=1)
        if isOpposing
            box.set_text(b, "OPP PDA")
            box.set_text_color(b, color.new(#FF9800, 0))
            box.set_text_size(b, size.tiny)
        array.push(fvgBoxes, b)
        array.push(fvgTypes, 1)

    if bearFVG
        isOpposing = inDiscount
        clr = isOpposing ? fvg_oppClr : fvg_bearClr
        b = box.new(bar_index - 2, low[2], bar_index + 30, high, bgcolor=clr, border_color=color.new(color.red, 60), border_width=1)
        if isOpposing
            box.set_text(b, "OPP PDA")
            box.set_text_color(b, color.new(#FF9800, 0))
            box.set_text_size(b, size.tiny)
        array.push(fvgBoxes, b)
        array.push(fvgTypes, -1)

    // Mitigate
    if fvg_mitigate and array.size(fvgBoxes) > 0
        for i = array.size(fvgBoxes) - 1 to 0
            bx = array.get(fvgBoxes, i)
            bxT = box.get_top(bx)
            bxB = box.get_bottom(bx)
            if high >= bxT and low <= bxB
                box.delete(bx)
                array.remove(fvgBoxes, i)
                array.remove(fvgTypes, i)

    while array.size(fvgBoxes) > fvg_maxBoxes
        box.delete(array.shift(fvgBoxes))
        array.shift(fvgTypes)


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  4. DISPLACEMENT (PHASE CHANGE)                                         ║
// ╚══════════════════════════════════════════════════════════════════════════╝

atrDisp  = ta.atr(disp_atrLen)
bodySize = math.abs(close - open)
isDispUp = disp_enable and bodySize > atrDisp * disp_atrMult and close > open
isDispDn = disp_enable and bodySize > atrDisp * disp_atrMult and close < open

barcolor(isDispUp ? color.new(#00E676, 40) : isDispDn ? color.new(#FF5252, 40) : na, title="Displacement Color")


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  5. CONSOLIDATION → EXPANSION → LIQUIDITY TARGET                       ║
// ╚══════════════════════════════════════════════════════════════════════════╝

rangeHi   = ta.highest(high, ce_lookback)
rangeLo   = ta.lowest(low, ce_lookback)
rangeSize = rangeHi - rangeLo
atrCE     = ta.atr(ce_lookback)

isConsolidating = ce_enable and (rangeSize < atrCE * ce_atrRatio * ce_lookback / 14.0)

// Detect expansion candle out of consolidation
expBody     = math.abs(close - open)
isExpansion = ce_enable and isConsolidating[1] and not isConsolidating and expBody > atrGlobal * ce_expMult
expBull     = isExpansion and close > open
expBear     = isExpansion and close < open

// Find nearest liquidity target in expansion direction
var float expTarget = na
if expBull and array.size(lqHighs) > 0
    nearestAbove = close + atrGlobal * 10
    for i = 0 to array.size(lqHighs) - 1
        lvl = array.get(lqHighs, i)
        if lvl > close and lvl < nearestAbove
            nearestAbove := lvl
    expTarget := nearestAbove < close + atrGlobal * 10 ? nearestAbove : na

if expBear and array.size(lqLows) > 0
    nearestBelow = close - atrGlobal * 10
    for i = 0 to array.size(lqLows) - 1
        lvl = array.get(lqLows, i)
        if lvl < close and lvl > nearestBelow
            nearestBelow := lvl
    expTarget := nearestBelow > close - atrGlobal * 10 ? nearestBelow : na

bgcolor(ce_enable and isConsolidating ? ce_boxClr : na, title="Consolidation BG")
if expBull
    label.new(bar_index, low, "EXP", style=label.style_label_up, color=color.new(#00BCD4, 0), textcolor=color.white, size=size.small)
if expBear
    label.new(bar_index, high, "EXP", style=label.style_label_down, color=color.new(#00BCD4, 0), textcolor=color.white, size=size.small)
plotshape(expBear, "Expansion↓", shape.arrowdown, location.abovebar, color.new(#00BCD4, 0), size=size.small, text="EXP")


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  6. KEY LEVELS — PDH/PDL/PDC/MIDNIGHT OPEN/WEEKLY                       ║
// ╚══════════════════════════════════════════════════════════════════════════╝

[pdh, pdl, pdc] = request.security(syminfo.tickerid, "D", [high[1], low[1], close[1]], lookahead=barmerge.lookahead_on)
[pwh, pwl]      = request.security(syminfo.tickerid, "W", [high[1], low[1]], lookahead=barmerge.lookahead_on)

var float midnightOpen = na
if hour(time, "America/New_York") == 0 and minute(time, "America/New_York") == 0
    midnightOpen := open

plot(lv_enable and lv_pdHL   ? pdh : na, "PDH", lv_pdhClr, 1, plot.style_stepline_diamond)
plot(lv_enable and lv_pdHL   ? pdl : na, "PDL", lv_pdhClr, 1, plot.style_stepline_diamond)
plot(lv_enable and lv_pdClose? pdc : na, "PDC", lv_pdcClr, 1, plot.style_stepline_diamond)
plot(lv_enable and lv_midOpen? midnightOpen : na, "Midnight Open", lv_midClr, 2, plot.style_stepline)
plot(lv_enable and lv_weekHL ? pwh : na, "PWH", lv_wkClr, 1, plot.style_stepline_diamond)
plot(lv_enable and lv_weekHL ? pwl : na, "PWL", lv_wkClr, 1, plot.style_stepline_diamond)

// Equilibrium line (mid-range exposure)
plot(equilibrium, "Equilibrium (50%)", color.new(#9E9E9E, 40), 1, plot.style_cross)


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  7. SESSIONS + SESSION H/L                                              ║
// ╚══════════════════════════════════════════════════════════════════════════╝

inAsia = sess_enable and sess_asia and f_inSession(20, 24)
inLDN  = sess_enable and sess_ldn  and f_inSession(2, 5)
inNY   = sess_enable and sess_nyAM and f_inSession(9, 12)
inNYPM = sess_enable and sess_nyPM and f_inSession(13, 16)

bgcolor(inAsia ? sess_asiaClr : na, title="Asia BG")
bgcolor(inLDN  ? sess_ldnClr  : na, title="LDN BG")
bgcolor(inNY   ? sess_nyClr   : na, title="NY AM BG")
bgcolor(inNYPM ? sess_nypmClr : na, title="NY PM BG")

var float sAsiaHi = na, var float sAsiaLo = na
var float sLdnHi  = na, var float sLdnLo  = na
var float sNyHi   = na, var float sNyLo   = na

if inAsia
    sAsiaHi := na(sAsiaHi) ? high : math.max(sAsiaHi, high)
    sAsiaLo := na(sAsiaLo) ? low  : math.min(sAsiaLo, low)
if not inAsia and inAsia[1]
    sAsiaHi := na
    sAsiaLo := na
if inLDN
    sLdnHi := na(sLdnHi) ? high : math.max(sLdnHi, high)
    sLdnLo := na(sLdnLo) ? low  : math.min(sLdnLo, low)
if not inLDN and inLDN[1]
    sLdnHi := na
    sLdnLo := na
if inNY
    sNyHi := na(sNyHi) ? high : math.max(sNyHi, high)
    sNyLo := na(sNyLo) ? low  : math.min(sNyLo, low)
if not inNY and inNY[1]
    sNyHi := na
    sNyLo := na

// We draw session lines by updating an array of lines or just drawing a single line segment
var line L_asiaHi = na, var line L_asiaLo = na
var line L_ldnHi  = na, var line L_ldnLo  = na
var line L_nyHi   = na, var line L_nyLo   = na

if inAsia
    if na(sAsiaHi[1]) or not inAsia[1]
        L_asiaHi := line.new(bar_index, sAsiaHi, bar_index, sAsiaHi, color=sess_asiaClr)
        L_asiaLo := line.new(bar_index, sAsiaLo, bar_index, sAsiaLo, color=sess_asiaClr)
    else
        line.set_y1(L_asiaHi, sAsiaHi)
        line.set_y2(L_asiaHi, sAsiaHi)
        line.set_x2(L_asiaHi, bar_index)
        line.set_y1(L_asiaLo, sAsiaLo)
        line.set_y2(L_asiaLo, sAsiaLo)
        line.set_x2(L_asiaLo, bar_index)

if inLDN
    if na(sLdnHi[1]) or not inLDN[1]
        L_ldnHi := line.new(bar_index, sLdnHi, bar_index, sLdnHi, color=sess_ldnClr)
        L_ldnLo := line.new(bar_index, sLdnLo, bar_index, sLdnLo, color=sess_ldnClr)
    else
        line.set_y1(L_ldnHi, sLdnHi)
        line.set_y2(L_ldnHi, sLdnHi)
        line.set_x2(L_ldnHi, bar_index)
        line.set_y1(L_ldnLo, sLdnLo)
        line.set_y2(L_ldnLo, sLdnLo)
        line.set_x2(L_ldnLo, bar_index)

if inNY
    if na(sNyHi[1]) or not inNY[1]
        L_nyHi := line.new(bar_index, sNyHi, bar_index, sNyHi, color=sess_nyClr)
        L_nyLo := line.new(bar_index, sNyLo, bar_index, sNyLo, color=sess_nyClr)
    else
        line.set_y1(L_nyHi, sNyHi)
        line.set_y2(L_nyHi, sNyHi)
        line.set_x2(L_nyHi, bar_index)
        line.set_y1(L_nyLo, sNyLo)
        line.set_y2(L_nyLo, sNyLo)
        line.set_x2(L_nyLo, bar_index)


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  8. VWAP + STANDARD DEVIATION BANDS                                     ║
// ╚══════════════════════════════════════════════════════════════════════════╝

var float vSumPV = 0.0, var float vSumV = 0.0, var float vSumPV2 = 0.0
if f_isNewDay()
    vSumPV := 0.0
    vSumV  := 0.0
    vSumPV2:= 0.0

tp = hlc3
vSumPV  += tp * volume
vSumV   += volume
vSumPV2 += tp * tp * volume

vwapVal = vSumV != 0 ? vSumPV / vSumV : na
vwapStd = vSumV != 0 ? math.sqrt(math.max((vSumPV2 / vSumV) - (vwapVal * vwapVal), 0)) : 0.0

vU1 = vwapVal + vwap_m1 * vwapStd
vL1 = vwapVal - vwap_m1 * vwapStd
vU2 = vwapVal + vwap_m2 * vwapStd
vL2 = vwapVal - vwap_m2 * vwapStd

plot(vwap_enable ? vwapVal : na, "VWAP", vwap_clr, 2)
pVU1 = plot(vwap_enable and vwap_bands ? vU1 : na, "VWAP +1σ", color.new(vwap_clr, 70))
pVL1 = plot(vwap_enable and vwap_bands ? vL1 : na, "VWAP -1σ", color.new(vwap_clr, 70))
pVU2 = plot(vwap_enable and vwap_bands ? vU2 : na, "VWAP +2σ", color.new(vwap_clr, 85))
pVL2 = plot(vwap_enable and vwap_bands ? vL2 : na, "VWAP -2σ", color.new(vwap_clr, 85))
fill(pVU1, pVL1, color.new(vwap_clr, 93), "VWAP Band 1")
fill(pVU2, pVL2, color.new(vwap_clr, 96), "VWAP Band 2")


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  9. ORDER FLOW — DELTA, RVOL, TRAPPED TRADERS                          ║
// ╚══════════════════════════════════════════════════════════════════════════╝

// Volume delta approximation
deltaApx = 0.0
if of_enable and volume > 0
    rng = high - low
    if rng > 0
        deltaApx := volume * ((close - low) / rng) - volume * ((high - close) / rng)
    else
        deltaApx := close >= open ? volume : -volume

var float cumDelta = 0.0
if f_isNewDay()
    cumDelta := 0.0
cumDelta += deltaApx

// RVOL
avgVol    = ta.sma(volume, of_rvolLen)
rvolRatio = avgVol > 0 ? volume / avgVol : 0.0
rvolHigh  = of_enable and rvolRatio >= of_rvolThresh

// ── Trapped Traders Detection ──
// Trapped longs: strong bullish candle followed by reversal that closes below its open
// (traders who bought the breakout are now underwater)
trappedLongs = of_trapped and close[1] > open[1] and (close[1] - open[1]) > atrGlobal * 1.0 and close < open[1] and volume > avgVol
// Trapped shorts: strong bearish candle followed by reversal closing above its open
trappedShorts = of_trapped and close[1] < open[1] and (open[1] - close[1]) > atrGlobal * 1.0 and close > open[1] and volume > avgVol

// Failed auction (sweep + rejection with volume)
failedAuctionHi = high > high[1] and close < low[1] and rvolHigh
failedAuctionLo = low < low[1] and close > high[1] and rvolHigh

if trappedLongs
    label.new(bar_index, high, "TRAP", style=label.style_label_down, color=color.new(#FF5252, 20), textcolor=color.white, size=size.tiny)
if trappedShorts
    label.new(bar_index, low, "TRAP", style=label.style_label_up, color=color.new(#00E676, 20), textcolor=color.white, size=size.tiny)
plotshape(trappedShorts, "Trapped Shorts", shape.xcross, location.belowbar, color.new(#00E676, 20), size=size.tiny, text="TRAP")


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  10. MOVING AVERAGES                                                    ║
// ╚══════════════════════════════════════════════════════════════════════════╝

emaFast  = ta.ema(close, ma_fastLen)
emaSlow  = ta.ema(close, ma_slowLen)
smaTrend = ta.sma(close, ma_trendLen)

plot(ma_enable ? emaFast  : na, "Fast EMA",  ma_fastClr,  1)
plot(ma_enable ? emaSlow  : na, "Slow EMA",  ma_slowClr,  1)
plot(ma_enable ? smaTrend : na, "Trend SMA", ma_trendClr, 2)


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  11. HTF CONFIRMATION + HTF LIQUIDITY SWEEP CHECK                       ║
// ╚══════════════════════════════════════════════════════════════════════════╝

htfEma   = request.security(syminfo.tickerid, htf_tf, ta.ema(close, htf_emaLen), lookahead=barmerge.lookahead_off)
htfClose = request.security(syminfo.tickerid, htf_tf, close, lookahead=barmerge.lookahead_off)
htfHigh  = request.security(syminfo.tickerid, htf_tf, high, lookahead=barmerge.lookahead_off)
htfLow   = request.security(syminfo.tickerid, htf_tf, low, lookahead=barmerge.lookahead_off)

htfBull = htf_enable ? htfClose > htfEma : true
htfBear = htf_enable ? htfClose < htfEma : true

// HTF swing high/low for liquidity pool sweep detection
htfSwH = request.security(syminfo.tickerid, htf_tf, ta.pivothigh(high, htf_swingLen, htf_swingLen), lookahead=barmerge.lookahead_off)
htfSwL = request.security(syminfo.tickerid, htf_tf, ta.pivotlow(low, htf_swingLen, htf_swingLen), lookahead=barmerge.lookahead_off)

var float lastHTFSwH = na
var float lastHTFSwL = na
if not na(htfSwH)
    lastHTFSwH := htfSwH
if not na(htfSwL)
    lastHTFSwL := htfSwL

// HTF liquidity sweep detection
htfBuySweep  = not na(lastHTFSwH) and htfHigh > lastHTFSwH and htfClose < lastHTFSwH
htfSellSweep = not na(lastHTFSwL) and htfLow < lastHTFSwL and htfClose > lastHTFSwL

var bool htfBuySweepFlag  = false
var bool htfSellSweepFlag = false

if htfBuySweep and not htfBuySweep[1]
    htfBuySweepFlag := true
else
    htfBuySweepFlag := false

if htfSellSweep and not htfSellSweep[1]
    htfSellSweepFlag := true
else
    htfSellSweepFlag := false


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  12. MARKET PROFILE — POC & VALUE AREA                                  ║
// ╚══════════════════════════════════════════════════════════════════════════╝

var float pocLevel = na
var float vaHigh   = na
var float vaLow    = na

// Series functions must run on every bar (cannot be inside if barstate.islast)
profileHi = ta.highest(high, mp_len)
profileLo = ta.lowest(low, mp_len)
profileRowSize = (profileHi - profileLo) / mp_rows

if mp_enable and barstate.islast
    if profileRowSize > 0
        // Count volume at each price row
        maxVol   = 0.0
        maxRow   = 0
        totalVol = 0.0

        volArr = array.new<float>(mp_rows, 0.0)

        for b = 0 to mp_len - 1
            for r = 0 to mp_rows - 1
                rowLo = profileLo + r * profileRowSize
                rowHi = rowLo + profileRowSize
                barLo = low[b]
                barHi = high[b]
                // If bar overlaps this row, allocate proportional volume
                overlap = math.max(0.0, math.min(barHi, rowHi) - math.max(barLo, rowLo))
                barRng  = barHi - barLo
                if barRng > 0 and overlap > 0
                    proportion = overlap / barRng
                    allocated  = volume[b] * proportion
                    currentVol = array.get(volArr, r) + allocated
                    array.set(volArr, r, currentVol)

        // Find POC (row with max volume)
        for r = 0 to mp_rows - 1
            rv = array.get(volArr, r)
            totalVol += rv
            if rv > maxVol
                maxVol := rv
                maxRow := r

        pocLevel := profileLo + (maxRow + 0.5) * profileRowSize

        // Value Area (70% of volume around POC)
        vaTarget = totalVol * 0.70
        vaVol    = maxVol
        hiIdx    = maxRow
        loIdx    = maxRow

        for _step = 0 to mp_rows - 1
            if vaVol >= vaTarget
                break
            addHi = hiIdx < mp_rows - 1 ? array.get(volArr, hiIdx + 1) : 0.0
            addLo = loIdx > 0           ? array.get(volArr, loIdx - 1) : 0.0
            if addHi >= addLo and hiIdx < mp_rows - 1
                hiIdx += 1
                vaVol += addHi
            else if loIdx > 0
                loIdx -= 1
                vaVol += addLo
            else
                break

        vaHigh := profileLo + (hiIdx + 1) * profileRowSize
        vaLow  := profileLo + loIdx * profileRowSize

plot(mp_enable ? pocLevel : na, "POC", mp_pocClr, 2, plot.style_cross)
plot(mp_enable ? vaHigh   : na, "VA High", color.new(#2196F3, 50), 1, plot.style_cross)
plot(mp_enable ? vaLow    : na, "VA Low",  color.new(#2196F3, 50), 1, plot.style_cross)


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  13. MID-RANGE EXPOSURE DETECTION                                       ║
// ╚══════════════════════════════════════════════════════════════════════════╝

// When price is in the middle 20% of the range = "no man's land"
rangeMid   = equilibrium
midZoneHi  = equilibrium + (swRangeHi - swRangeLo) * 0.10
midZoneLo  = equilibrium - (swRangeHi - swRangeLo) * 0.10
inMidRange = close >= midZoneLo and close <= midZoneHi

// Flag mid-range as lower-probability zone
bgcolor(inMidRange and ce_enable ? color.new(#9E9E9E, 95) : na, title="Mid-Range Zone")


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  14. DIRECTIONAL BIAS ENGINE                                            ║
// ╚══════════════════════════════════════════════════════════════════════════╝

// Composite bias from liquidity positioning, order flow, candle closures
var int biasBull = 0
var int biasBear = 0
biasBull := 0
biasBear := 0

// --- Candle closure analysis ---
// Close position within range
closePos = high != low ? (close - low) / (high - low) : 0.5

// Strong close (above 70% = bullish conviction, below 30% = bearish conviction)
if closePos > 0.70
    biasBull += 2
else if closePos < 0.30
    biasBear += 2
else if closePos > 0.55
    biasBull += 1
else if closePos < 0.45
    biasBear += 1

// --- Order flow bias ---
if deltaApx > 0 and rvolHigh
    biasBull += 2
else if deltaApx > 0
    biasBull += 1
if deltaApx < 0 and rvolHigh
    biasBear += 2
else if deltaApx < 0
    biasBear += 1

// Cumulative delta trend
if cumDelta > 0 and cumDelta > cumDelta[5]
    biasBull += 1
if cumDelta < 0 and cumDelta < cumDelta[5]
    biasBear += 1

// --- Liquidity positioning ---
// Price relative to midnight open (daily bias anchor)
if not na(midnightOpen)
    if close > midnightOpen
        biasBull += 2
    else
        biasBear += 2

// Price relative to VWAP
if not na(vwapVal)
    if close > vwapVal
        biasBull += 1
    else
        biasBear += 1

// Market structure trend
if msTrend == 1
    biasBull += 2
else if msTrend == -1
    biasBear += 2

// HTF alignment
if htfBull
    biasBull += 2
if htfBear
    biasBear += 2

// EMA alignment
if ma_enable and emaFast > emaSlow and close > smaTrend
    biasBull += 2
else if ma_enable and emaFast < emaSlow and close < smaTrend
    biasBear += 2

// Premium/Discount zone
if inDiscount
    biasBull += 1    // discount = buy zone
if inPremium
    biasBear += 1    // premium = sell zone

// Sweep reversals (powerful bias)
if sweepBullReversal
    biasBull += 3
if sweepBearReversal
    biasBear += 3

// HTF sweep events
if htfSellSweepFlag
    biasBull += 2
if htfBuySweepFlag
    biasBear += 2

// Trapped traders (fuel for the other side)
if trappedLongs
    biasBear += 2
if trappedShorts
    biasBull += 2

// Consolidation expansion
if expBull
    biasBull += 2
if expBear
    biasBear += 2

// Total bias
biasTotal = biasBull + biasBear
biasNet   = biasBull - biasBear  // positive = bullish, negative = bearish

// Directional bias string
biasDir = biasNet > 4 ? "STRONG BULL" : biasNet > 1 ? "LEAN BULL" : biasNet < -4 ? "STRONG BEAR" : biasNet < -1 ? "LEAN BEAR" : "NEUTRAL"
biasClr = biasNet > 4 ? ms_bullClr : biasNet > 1 ? color.new(#00E676, 40) : biasNet < -4 ? ms_bearClr : biasNet < -1 ? color.new(#FF5252, 40) : color.gray


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  15. CONFLUENCE SCORING & PROBABILITY ENGINE                            ║
// ╚══════════════════════════════════════════════════════════════════════════╝

atrVal = ta.atr(atr_length)

// ── Bullish Confluence ──
bullConf = 0
if ms_enable and msTrend == 1
    bullConf += 1
if chochUp
    bullConf += 2
if isDispUp
    bullConf += 2
if sweepBullReversal
    bullConf += 3
if vwap_enable and close > vwapVal
    bullConf += 1
if ma_enable and emaFast > emaSlow
    bullConf += 1
if ma_enable and close > smaTrend
    bullConf += 1
if htfBull
    bullConf += 1
if deltaApx > 0
    bullConf += 1
if rvolHigh
    bullConf += 1
if not na(midnightOpen) and close > midnightOpen
    bullConf += 1
if inDiscount
    bullConf += 1
if trappedShorts
    bullConf += 2
if htfSellSweepFlag
    bullConf += 2
if not na(pocLevel) and math.abs(close - pocLevel) < atrVal * 0.5
    bullConf += 1  // near POC = strong level
if expBull
    bullConf += 2

// ── Bearish Confluence ──
bearConf = 0
if ms_enable and msTrend == -1
    bearConf += 1
if chochDn
    bearConf += 2
if isDispDn
    bearConf += 2
if sweepBearReversal
    bearConf += 3
if vwap_enable and close < vwapVal
    bearConf += 1
if ma_enable and emaFast < emaSlow
    bearConf += 1
if ma_enable and close < smaTrend
    bearConf += 1
if htfBear
    bearConf += 1
if deltaApx < 0
    bearConf += 1
if rvolHigh
    bearConf += 1
if not na(midnightOpen) and close < midnightOpen
    bearConf += 1
if inPremium
    bearConf += 1
if trappedLongs
    bearConf += 2
if htfBuySweepFlag
    bearConf += 2
if not na(pocLevel) and math.abs(close - pocLevel) < atrVal * 0.5
    bearConf += 1
if expBear
    bearConf += 2

// ICT Time Macros & Silver Bullet Boost
if ict_enable and (f_isIctMacro() or f_isSilverBullet())
    bullConf += 2
    bearConf += 2

// ── Mid-range penalty ──
if inMidRange
    bullConf -= 2
    bearConf -= 2

// Clamp
bullConf := math.max(bullConf, 0)
bearConf := math.max(bearConf, 0)

// ── Probability calculation ──
maxPossibleConf = 22  // theoretical max score
bullProb = math.min(math.round(bullConf / maxPossibleConf * 100), 95)
bearProb = math.min(math.round(bearConf / maxPossibleConf * 100), 95)

// ── Signal firing ──
inAnySession = inAsia or inLDN or inNY or inNYPM
sessionAllowed = not trade_sessOnly or inAnySession

bullTrigger = bullConf >= sig_minConf and bullProb >= sig_minProb and not inMidRange and sessionAllowed
bearTrigger = bearConf >= sig_minConf and bearProb >= sig_minProb and not inMidRange and sessionAllowed

bullSignal = bullTrigger and not bullTrigger[1]
bearSignal = bearTrigger and not bearTrigger[1]

// Signal labels with probability
if bullSignal
    txt = "BUY\n" + str.tostring(bullProb) + "% prob\nConf: " + str.tostring(bullConf)
    label.new(bar_index, low - atrVal * 0.5, txt, style=label.style_label_up, color=color.new(#00E676, 10), textcolor=color.white, size=size.normal)

if bearSignal
    txt = "SELL\n" + str.tostring(bearProb) + "% prob\nConf: " + str.tostring(bearConf)
    label.new(bar_index, high + atrVal * 0.5, txt, style=label.style_label_down, color=color.new(#FF5252, 10), textcolor=color.white, size=size.normal)

// ATR Stop/Target levels
if atr_enable and bullSignal
    sl  = close - atrVal * atr_stopMult
    tp1 = close + atrVal * atr_tp1Mult
    tp2 = close + atrVal * atr_tp2Mult
    label.new(bar_index, sl,  "SL " + str.tostring(sl, format.mintick),  style=label.style_label_up,   color=color.new(#FF5252, 40), textcolor=color.white, size=size.tiny)
    label.new(bar_index, tp1, "TP1 " + str.tostring(tp1, format.mintick), style=label.style_label_down, color=color.new(#00E676, 40), textcolor=color.white, size=size.tiny)
    label.new(bar_index, tp2, "TP2 " + str.tostring(tp2, format.mintick), style=label.style_label_down, color=color.new(#4CAF50, 40), textcolor=color.white, size=size.tiny)

if atr_enable and bearSignal
    sl  = close + atrVal * atr_stopMult
    tp1 = close - atrVal * atr_tp1Mult
    tp2 = close - atrVal * atr_tp2Mult
    label.new(bar_index, sl,  "SL " + str.tostring(sl, format.mintick),  style=label.style_label_down, color=color.new(#FF5252, 40), textcolor=color.white, size=size.tiny)
    label.new(bar_index, tp1, "TP1 " + str.tostring(tp1, format.mintick), style=label.style_label_up,   color=color.new(#00E676, 40), textcolor=color.white, size=size.tiny)
    label.new(bar_index, tp2, "TP2 " + str.tostring(tp2, format.mintick), style=label.style_label_up,   color=color.new(#4CAF50, 40), textcolor=color.white, size=size.tiny)


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  16. MASTER DASHBOARD                                                   ║
// ╚══════════════════════════════════════════════════════════════════════════╝

var table dash = table.new(position.top_right, 2, 20, bgcolor=color.new(#0D0D0D, 5), border_color=color.new(#333333, 0), border_width=1)

if barstate.islast
    row = 0

    // Header
    table.cell(dash, 0, row, "  EM-FSE Strat 3.0  ", text_color=color.white, text_size=size.small, bgcolor=color.new(#2196F3, 20))
    table.merge_cells(dash, 0, row, 1, row)
    row += 1

    // Directional Bias
    table.cell(dash, 0, row, " BIAS", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, row, biasDir, text_color=biasClr, text_size=size.tiny, bgcolor=color.new(biasClr, 90))
    row += 1

    // Probability
    table.cell(dash, 0, row, " Probability", text_color=color.gray, text_size=size.tiny)
    probTxt = bullProb > bearProb ? str.tostring(bullProb) + "% BULL" : bearProb > bullProb ? str.tostring(bearProb) + "% BEAR" : "FLAT"
    probClr = bullProb > bearProb ? ms_bullClr : bearProb > bullProb ? ms_bearClr : color.gray
    table.cell(dash, 1, row, probTxt, text_color=probClr, text_size=size.tiny)
    row += 1

    // Market Structure
    table.cell(dash, 0, row, " Structure", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, row, msTrend == 1 ? "BULLISH" : "BEARISH", text_color=msTrend == 1 ? ms_bullClr : ms_bearClr, text_size=size.tiny)
    row += 1

    // HTF Bias
    table.cell(dash, 0, row, " HTF Bias", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, row, htfBull ? "BULL" : htfBear ? "BEAR" : "NEUTRAL", text_color=htfBull ? ms_bullClr : ms_bearClr, text_size=size.tiny)
    row += 1

    // HTF LQ Sweep
    htfSweepTxt = htfBuySweepFlag ? "BUYSIDE SWEPT" : htfSellSweepFlag ? "SELLSIDE SWEPT" : "NONE"
    htfSweepClr = htfBuySweepFlag ? ms_bearClr : htfSellSweepFlag ? ms_bullClr : color.gray
    table.cell(dash, 0, row, " HTF LQ Sweep", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, row, htfSweepTxt, text_color=htfSweepClr, text_size=size.tiny)
    row += 1

    // Premium / Discount
    table.cell(dash, 0, row, " P/D Zone", text_color=color.gray, text_size=size.tiny)
    pdTxt = inMidRange ? "MID-RANGE" : inPremium ? "PREMIUM" : "DISCOUNT"
    pdClr = inMidRange ? color.new(#9E9E9E, 0) : inPremium ? ms_bearClr : ms_bullClr
    table.cell(dash, 1, row, pdTxt, text_color=pdClr, text_size=size.tiny)
    row += 1

    // vs VWAP
    table.cell(dash, 0, row, " vs VWAP", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, row, close > vwapVal ? "ABOVE" : "BELOW", text_color=close > vwapVal ? ms_bullClr : ms_bearClr, text_size=size.tiny)
    row += 1

    // vs Midnight Open
    table.cell(dash, 0, row, " vs MidOpen", text_color=color.gray, text_size=size.tiny)
    moTxt = na(midnightOpen) ? "N/A" : close > midnightOpen ? "ABOVE" : "BELOW"
    moClr = na(midnightOpen) ? color.gray : close > midnightOpen ? ms_bullClr : ms_bearClr
    table.cell(dash, 1, row, moTxt, text_color=moClr, text_size=size.tiny)
    row += 1

    // POC
    table.cell(dash, 0, row, " POC", text_color=color.gray, text_size=size.tiny)
    pocTxt = na(pocLevel) ? "N/A" : str.tostring(pocLevel, format.mintick)
    table.cell(dash, 1, row, pocTxt, text_color=mp_pocClr, text_size=size.tiny)
    row += 1

    // RVOL
    table.cell(dash, 0, row, " RVOL", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, row, str.tostring(rvolRatio, "#.##") + "x", text_color=rvolHigh ? color.lime : color.gray, text_size=size.tiny)
    row += 1

    // Delta
    table.cell(dash, 0, row, " Delta", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, row, (deltaApx > 0 ? "+" : "") + str.tostring(deltaApx, "#"), text_color=deltaApx > 0 ? ms_bullClr : ms_bearClr, text_size=size.tiny)
    row += 1

    // CumDelta
    table.cell(dash, 0, row, " CumDelta", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, row, (cumDelta > 0 ? "+" : "") + str.tostring(cumDelta, "#"), text_color=cumDelta > 0 ? ms_bullClr : ms_bearClr, text_size=size.tiny)
    row += 1

    // Consolidation State
    table.cell(dash, 0, row, " Consolidation", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, row, isConsolidating ? "YES — WATCH" : "NO", text_color=isConsolidating ? color.new(#FF9800, 0) : color.gray, text_size=size.tiny)
    row += 1

    // Trapped Flow
    trapTxt = trappedLongs ? "LONGS TRAPPED" : trappedShorts ? "SHORTS TRAPPED" : "NONE"
    trapClr = trappedLongs ? ms_bearClr : trappedShorts ? ms_bullClr : color.gray
    table.cell(dash, 0, row, " Trapped Flow", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, row, trapTxt, text_color=trapClr, text_size=size.tiny)
    row += 1

    // ATR
    table.cell(dash, 0, row, " ATR", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, row, str.tostring(atrVal, format.mintick), text_color=color.white, text_size=size.tiny)
    row += 1

    // Confluence scores
    table.cell(dash, 0, row, " Bull Score", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, row, str.tostring(bullConf) + " / " + str.tostring(maxPossibleConf), text_color=bullConf >= sig_minConf ? ms_bullClr : color.gray, text_size=size.tiny)
    row += 1

    table.cell(dash, 0, row, " Bear Score", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, row, str.tostring(bearConf) + " / " + str.tostring(maxPossibleConf), text_color=bearConf >= sig_minConf ? ms_bearClr : color.gray, text_size=size.tiny)
    row += 1

    // Session
    sessT = inAsia ? "ASIA" : inLDN ? "LONDON" : inNY ? "NY AM" : inNYPM ? "NY PM" : "OFF"
    table.cell(dash, 0, row, " Session", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, row, sessT, text_color=color.white, text_size=size.tiny)
    row += 1


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  16.5 AUTO-TRADING STRATEGY EXECUTION                                   ║
// ╚══════════════════════════════════════════════════════════════════════════╝

if strat_enable
    // ── Module 6.4: Compounding & Position Growth Logic ──
    strat_slAbs = atrVal * atr_stopMult
    sys_riskRisk = strategy.equity * (strat_risk / 100)
    comp_qty = (strat_slAbs > 0 and syminfo.pointvalue > 0) ? (sys_riskRisk / (strat_slAbs * syminfo.pointvalue)) : 0
    final_qty = strat_comp ? math.max(math.floor(comp_qty), 1) : strat_qty  // Floor to whole futures contracts!

    if bullSignal
        strat_sl = close - atrVal * atr_stopMult
        strat_tp = close + atrVal * atr_tp1Mult
        strategy.entry("Long", strategy.long, qty=final_qty, alert_message=webhook_buy)
        strategy.exit("Exit L", "Long", stop=strat_sl, limit=strat_tp, alert_message="Exit Long")
    if bearSignal
        strat_sl = close + atrVal * atr_stopMult
        strat_tp = close - atrVal * atr_tp1Mult
        strategy.entry("Short", strategy.short, qty=final_qty, alert_message=webhook_sell)
        strategy.exit("Exit S", "Short", stop=strat_sl, limit=strat_tp, alert_message="Exit Short")

