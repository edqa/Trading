python3 - << 'PYEOF' """Apply NQ second-pass optimized parameters to em_fse_v6.pine -> em_fse_v6_NQ_optimized.pine""" with open("Code/em_fse_v6.pine", "r") as f: src = f.read() # ── Header ────────────────────────────────────────────────────────────────── HEADER = """\ // ============================================================================ // EM FUTURES STRATEGY v6.0 — NQ EDITION (SECOND-PASS OPTIMIZED) // © Edwin Maina — Optimized for NQ Futures (Tradeify $50k / $100k Prop) // ICT + Smart Money + Master Swing Confluence Engine // Pine Script v6 // // PASS 1 NQ OPTIMIZATION (2026-04-14, 2-week data): // atr_stopMult 1.0 → 0.75 (SL fits $50k 1% risk per contract) // atr_tp1Mult 3.0 → 2.0 (achievable on 5min, ~35% hit rate) // atr_tp2Mult 3.0 → 4.0 (let trail extend) // disp_atrMult 2.0 → 1.5 (3x more displacement signals) // lq_sweepWick 0.30 → 0.40 (41%→28% of bars qualify as sweep) // of_rvolThresh 1.5 → 2.0 (16%→8.1% of bars qualify) // fvg_minATR 0.3 → 0.2 (capture more NQ imbalances) // dow_mon 0.7 → 1.1 (Monday is NQ's highest-vol day) // dow_tue/wed calibrated, partial_pct 50→60, trail_atrMult 1.5→1.25 // sig_minConf 4 → 5 (higher bar for NQ noise) // prop_minwin 200 → 300 (NQ TP is larger) // prop_eod_min 45 → 30 (NQ gaps hard near close) // ce_enable true → false (formula never fires on NQ 5min) // // PASS 2 NQ OPTIMIZATION (2026-04-14, walk-forward 70/30 on 2,951 5min bars): // atr_stopMult 0.75 → 0.50 (OOS expectancy +0.95R; tighter SL NQ) // atr_tp1Mult 2.0 → 3.0 (OOS: 3.0 dominates across all combos) // disp_atrMult 1.5 → 1.25 (more displacement signals without noise) // lq_sweepWick 0.40 → 0.45 (stricter wick filter, cleaner reversals) // of_rvolThresh 2.0 → 2.5 (only true volume surges qualify) // sig_minConf 5 → 6 (raise bar further; fewer, cleaner trades) // // SESSION QUALITY (best params, full dataset): // London 02-05: 44.4% WR, +2.47R avg ← PRIMARY session // NY AM 09-12: 16.7% WR, +0.30R avg ← caution, low edge // NY PM 13-16: 0.0% WR, -1.00R avg ← AVOID // // DOW ANALYSIS (1hr NQ data): // Mon: range 125.6pts (best), Tue: vol 26,786 (highest) // Fri: lowest range 80.7pts, lowest volume // ============================================================================""" # Replace the original header block old_header = """\ // ============================================================================ // EM FUTURES STRATEGY v6.0 — MASTER SWING EDITION // © Edwin Maina — Designed for ES / NQ Futures // ICT + Smart Money + Master Swing Confluence Engine // Pine Script v6 // ============================================================================""" src = src.replace(old_header, HEADER, 1) # ── Strategy declaration ── src = src.replace( 'strategy("EM Tradeify Prop Strategy v6.0", shorttitle="EM-FSE v6.0 MSE"', 'strategy("EM Tradeify Prop Strategy v6.0 [NQ OPT2]", shorttitle="EM-FSE v6.0 NQ2"' ) # ── lq_sweepWick 0.30 → 0.45 ── src = src.replace( 'lq_sweepWick = input.float(0.3, "Min Wick Ratio for Sweep", step=0.05, group=grpLQ, tooltip="Wick must be this fraction of total range to qualify as sweep")', 'lq_sweepWick = input.float(0.45, "Min Wick Ratio for Sweep", step=0.05, group=grpLQ, tooltip="Wick must be this fraction of total range to qualify as sweep") // NQ OPT2: 0.30→0.45 (stricter sweep filter, cleaner reversals)' ) # ── fvg_minATR 0.3 → 0.2 ── src = src.replace( 'fvg_minATR = input.float(0.3, "Min FVG Size (ATR mult)", step=0.1, group=grpFVG)', 'fvg_minATR = input.float(0.2, "Min FVG Size (ATR mult)", step=0.1, group=grpFVG) // NQ OPT1: 0.3→0.2 (capture more NQ imbalances ~5.9pts min)' ) # ── disp_atrMult 2.0 → 1.25 ── src = src.replace( 'disp_atrMult = input.float(2.0, "ATR Multiple", step=0.1, group=grpDisp)', 'disp_atrMult = input.float(1.25, "ATR Multiple", step=0.1, group=grpDisp) // NQ OPT2: 2.0→1.25 (more signals, still strong displacement filter)' ) # ── ce_enable true → false ── src = src.replace( 'ce_enable = input.bool(true, "Enable Consolidation Detection", group=grpCE)', 'ce_enable = input.bool(false, "Enable Consolidation Detection", group=grpCE) // NQ OPT1: disabled — formula never triggers on NQ 5min; re-enable on daily TF' ) # ── atr_stopMult 1.0 → 0.50 ── src = src.replace( 'atr_stopMult = input.float(1.0, "SL ATR Multiple", step=0.1, group=grpATR)', 'atr_stopMult = input.float(0.50, "SL ATR Multiple", step=0.1, group=grpATR) // NQ OPT2: 1.0→0.50 (OOS best; tighter SL improves expectancy)' ) # ── atr_tp1Mult 3.0 → 3.0 (pass 2 restores to 3.0) ── src = src.replace( 'atr_tp1Mult = input.float(3.0, "TP1 ATR Multiple", step=0.1, group=grpATR)', 'atr_tp1Mult = input.float(3.0, "TP1 ATR Multiple", step=0.1, group=grpATR) // NQ OPT2: pass-1 used 2.0; pass-2 confirms 3.0 optimal OOS' ) # ── atr_tp2Mult 3.0 → 4.0 ── src = src.replace( 'atr_tp2Mult = input.float(3.0, "TP2 ATR Multiple", step=0.1, group=grpATR)', 'atr_tp2Mult = input.float(4.0, "TP2 ATR Multiple", step=0.1, group=grpATR) // NQ OPT1: 3.0→4.0 (let trail extend on NQ trending moves)' ) # ── sig_minConf 4 → 6 ── src = src.replace( 'sig_minConf = input.int(4, "Min Confluence for Signal", minval=1, maxval=15, group=grpSig)', 'sig_minConf = input.int(6, "Min Confluence for Signal", minval=1, maxval=15, group=grpSig) // NQ OPT2: 4→6 (walk-forward confirms 6 minimises noise on NQ 5min)' ) # ── DOW weights (NQ calibrated from 1hr range data) ── src = src.replace( 'dow_mon = input.float(0.7, "Monday Weight", step=0.1, minval=0, maxval=2, group=grpDOW)', 'dow_mon = input.float(1.1, "Monday Weight", step=0.1, minval=0, maxval=2, group=grpDOW) // NQ OPT1: 0.7→1.1 (Mon = highest range day 125.6pts)' ) src = src.replace( 'dow_tue = input.float(1.3, "Tuesday Weight", step=0.1, minval=0, maxval=2, group=grpDOW)', 'dow_tue = input.float(1.2, "Tuesday Weight", step=0.1, minval=0, maxval=2, group=grpDOW) // NQ OPT1: 1.3→1.2 (highest volume day)' ) src = src.replace( 'dow_wed = input.float(1.3, "Wednesday Weight", step=0.1, minval=0, maxval=2, group=grpDOW)', 'dow_wed = input.float(1.0, "Wednesday Weight", step=0.1, minval=0, maxval=2, group=grpDOW) // NQ OPT1: 1.3→1.0' ) src = src.replace( 'dow_thu = input.float(1.0, "Thursday Weight", step=0.1, minval=0, maxval=2, group=grpDOW)', 'dow_thu = input.float(0.9, "Thursday Weight", step=0.1, minval=0, maxval=2, group=grpDOW) // NQ OPT1: 1.0→0.9' ) src = src.replace( 'dow_fri = input.float(0.5, "Friday Weight", step=0.1, minval=0, maxval=2, group=grpDOW)', 'dow_fri = input.float(0.6, "Friday Weight", step=0.1, minval=0, maxval=2, group=grpDOW) // NQ OPT1: 0.5→0.6' ) # ── of_rvolThresh 1.5 → 2.5 ── src = src.replace( 'of_rvolThresh = input.float(1.5, "RVOL Threshold", step=0.1, group=grpOF)', 'of_rvolThresh = input.float(2.5, "RVOL Threshold", step=0.1, group=grpOF) // NQ OPT2: 1.5→2.5 (only true volume surges qualify, ~6% of bars)' ) # ── prop_minwin 200 → 300 ── src = src.replace( 'prop_minwin = input.float(200.0, "", inline="min", group=grpProp)', 'prop_minwin = input.float(300.0, "", inline="min", group=grpProp) // NQ OPT1: 200→300 (NQ TP is larger, filter weak R:R)' ) # ── prop_eod_min 45 → 30 ── src = src.replace( 'prop_eod_min = input.int(45, ":", inline="eod", minval=0, maxval=59, group=grpProp)', 'prop_eod_min = input.int(30, ":", inline="eod", minval=0, maxval=59, group=grpProp) // NQ OPT1: 45→30 (NQ gaps hard near close, avoid last 30min)' ) # ── partial_pct 50 → 60 ── src = src.replace( 'partial_pct = input.float(50.0, "% to Close at TP1", step=10, minval=10, maxval=90, group=grpPartial)', 'partial_pct = input.float(60.0, "% to Close at TP1", step=10, minval=10, maxval=90, group=grpPartial) // NQ OPT1: 50→60 (bank more at TP1 due to NQ snap-backs)' ) # ── trail_atrMult 1.5 → 1.25 ── src = src.replace( 'trail_atrMult = input.float(1.5, "Trail Stop ATR Multiple", step=0.1, group=grpPartial)', 'trail_atrMult = input.float(1.25, "Trail Stop ATR Multiple", step=0.1, group=grpPartial) // NQ OPT1: 1.5→1.25 (tighter trail for NQ reversals)' ) # ── Update footer ── src = src.replace( "// END — EM FUTURES STRATEGY v6.0 — MASTER SWING EDITION", "// END — EM FUTURES STRATEGY v6.0 — NQ EDITION (SECOND-PASS OPTIMIZED)" ) out_path = "Code/em_fse_v6_NQ_optimized.pine" with open(out_path, "w") as f: f.write(src) print(f"Written: {out_path} ({len(src.splitlines())} lines)") # Quick sanity check key values import re checks = { "atr_stopMult 0.50": "input.float(0.50", "atr_tp1Mult 3.0": "input.float(3.0", "disp_atrMult 1.25": "input.float(1.25", "lq_sweepWick 0.45": "input.float(0.45", "of_rvolThresh 2.5": "input.float(2.5", "sig_minConf 6": "input.int(6", "ce_enable false": "input.bool(false", "partial_pct 60": "input.float(60.0", "prop_eod_min 30": "input.int(30", "trail_atrMult 1.25":"input.float(1.25", } print("\nSanity checks:") for label, pattern in checks.items(): count = src.count(pattern) ok = "OK" if count >= 1 else "MISSING" print(f" {label:22s}: {ok} (found {count}x)") PYEOF